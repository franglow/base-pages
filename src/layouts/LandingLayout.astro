---
import '../styles/global.css';
import SEOHead from '../components/seo/SEOHead.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  lang?: string;
  jsonLd?: object | object[];
  hreflangLinks?: { lang: string; href: string }[];
}

const {
  title,
  description = 'High-performance landing page built by base-pages. Expert-crafted Astro sites with premium design.',
  canonicalUrl = 'https://base-pages.com/',
  ogImage,
  ogType,
  lang = 'en',
  jsonLd,
  hreflangLinks,
} = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Mono:wght@700&display=swap" rel="stylesheet">
    <SEOHead
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      ogType={ogType}
      locale={lang}
      jsonLd={jsonLd}
      hreflangLinks={hreflangLinks}
    />
    <slot name="head" />
  </head>
  <body class="bg-[#f8f7f5] text-[#111827] antialiased">
    
    <svg style="width: 0; height: 0; position: absolute;" aria-hidden="true" focusable="false">
      <defs>
        <linearGradient id="brand-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#A8BFAF" />
          <stop offset="50%" stop-color="#E8DDC8" />
          <stop offset="100%" stop-color="#F6D7C8" />
        </linearGradient>

        <filter id="liquid-filter" x="-20%" y="-20%" width="140%" height="140%">
          <feTurbulence type="fractalNoise" baseFrequency="0.005" numOctaves="1" result="noise" id="disp-noise"/>
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="0" xChannelSelector="R" yChannelSelector="G" id="disp-map"/>
        </filter>
      </defs>
    </svg>

    <slot />

    <CookieConsent />
  </body>
</html>