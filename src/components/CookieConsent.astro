---
/**
 * GDPR-compliant Cookie Consent using CookieConsent v3 by Orest Bida.
 *
 * FIX: Uses the ESM build inside <script type="module"> so the library
 * executes in module scope — completely isolating its minified variables
 * (like 'e') from Astro/Vite's global-scope bundles.
 *
 * Footer trigger:
 *   <button data-cc="show-preferencesModal">Manage Cookies</button>
 */
---

<!-- CookieConsent v3 — CSS from CDN -->
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/gh/orestbida/cookieconsent@3.0.1/dist/cookieconsent.css"
/>

<!-- Module script: ESM import keeps everything in its own scope -->
<script is:inline type="module">
  import * as CookieConsent from 'https://cdn.jsdelivr.net/gh/orestbida/cookieconsent@3.0.1/dist/cookieconsent.esm.js';

  // Idempotency guard — skip if already initialized
  if (window.__bp_cc_init) { /* noop */ } else {
    window.__bp_cc_init = true;

    // ─── GA4 loader ────────────────────────────────────────
    function loadGA4() {
      if (document.getElementById('ga4-script')) return;
      var GA_ID = 'G-RS6ZLBH3TX';

      var s = document.createElement('script');
      s.id = 'ga4-script';
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
      document.head.appendChild(s);

      window.dataLayer = window.dataLayer || [];
      function gtag() { window.dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', GA_ID, { anonymize_ip: true });
    }

    // ─── Language detection ────────────────────────────────
    var htmlLang = document.documentElement.lang || 'en';
    var ccLang = ['de', 'es'].indexOf(htmlLang) !== -1 ? htmlLang : 'en';

    // ─── Run CookieConsent ─────────────────────────────────
    CookieConsent.run({

      cookie: {
        name: 'bp_cc',
        expiresAfterDays: 365,
      },

      guiOptions: {
        consentModal: {
          layout: 'box inline',
          position: 'bottom left',
          equalWeightButtons: true,
          flipButtons: false,
        },
        preferencesModal: {
          layout: 'box',
          equalWeightButtons: true,
          flipButtons: false,
        },
      },

      categories: {
        necessary: {
          enabled: true,
          readOnly: true,
        },
        analytics: {
          autoClear: {
            cookies: [
              { name: /^_ga/ },
              { name: '_gid' },
            ],
          },
        },
      },

      onConsent: function () {
        if (CookieConsent.acceptedCategory('analytics')) {
          loadGA4();
        }
      },

      onFirstConsent: function () {
        // Notify other components (e.g. CalEmbed) that consent was granted
        window.dispatchEvent(new CustomEvent('bp:consent-change'));
        if (CookieConsent.acceptedCategory('analytics')) {
          loadGA4();
        }
      },

      onChange: function (param) {
        // Notify other components of mid-session consent changes
        window.dispatchEvent(new CustomEvent('bp:consent-change'));
        if (param.changedCategories.indexOf('analytics') !== -1) {
          if (CookieConsent.acceptedCategory('analytics')) {
            loadGA4();
          }
        }
      },

      language: {
        default: ccLang,
        autoDetect: 'document',

        translations: {
          en: {
            consentModal: {
              title: 'We respect your privacy',
              description:
                'We use cookies to analyze site usage and improve your experience. You can accept or reject non-essential cookies below. <a href="/privacy" class="cc-link">Privacy Policy</a>',
              acceptAllBtn: 'Accept All',
              acceptNecessaryBtn: 'Reject All',
              showPreferencesBtn: 'Manage Preferences',
            },
            preferencesModal: {
              title: 'Cookie Preferences',
              acceptAllBtn: 'Accept All',
              acceptNecessaryBtn: 'Reject All',
              savePreferencesBtn: 'Save Preferences',
              closeIconLabel: 'Close',
              sections: [
                {
                  title: 'Cookie Usage',
                  description:
                    'We use cookies to ensure the basic functionality of our website and to enhance your experience. You can choose which categories to opt-in to at any time. For more details, read our <a href="/privacy" class="cc-link">Privacy Policy</a> and <a href="/impressum" class="cc-link">Legal Notice</a>.',
                },
                {
                  title: 'Essential Cookies',
                  description:
                    'These cookies are strictly necessary for the website to function and cannot be disabled.',
                  linkedCategory: 'necessary',
                },
                {
                  title: 'Analytics Cookies',
                  description:
                    'These cookies help us understand how visitors interact with our website by collecting anonymous usage data. We use Google Analytics for this purpose.',
                  linkedCategory: 'analytics',
                },
                {
                  title: 'More Information',
                  description:
                    'For any questions regarding our cookie policy, please <a href="/contact" class="cc-link">contact us</a>.',
                },
              ],
            },
          },

          de: {
            consentModal: {
              title: 'Wir respektieren Ihre Privatsph\u00e4re',
              description:
                'Wir verwenden Cookies, um die Nutzung der Website zu analysieren und Ihr Erlebnis zu verbessern. Sie k\u00f6nnen nicht-essenzielle Cookies unten akzeptieren oder ablehnen. <a href="/de/privacy" class="cc-link">Datenschutz</a>',
              acceptAllBtn: 'Alle akzeptieren',
              acceptNecessaryBtn: 'Alle ablehnen',
              showPreferencesBtn: 'Einstellungen verwalten',
            },
            preferencesModal: {
              title: 'Cookie-Einstellungen',
              acceptAllBtn: 'Alle akzeptieren',
              acceptNecessaryBtn: 'Alle ablehnen',
              savePreferencesBtn: 'Einstellungen speichern',
              closeIconLabel: 'Schlie\u00dfen',
              sections: [
                {
                  title: 'Cookie-Nutzung',
                  description:
                    'Wir verwenden Cookies, um die grundlegende Funktionalit\u00e4t unserer Website sicherzustellen und Ihr Erlebnis zu verbessern. Sie k\u00f6nnen jederzeit w\u00e4hlen, welche Kategorien Sie zulassen m\u00f6chten. Weitere Informationen finden Sie in unserer <a href="/de/privacy" class="cc-link">Datenschutzerkl\u00e4rung</a> und im <a href="/de/impressum" class="cc-link">Impressum</a>.',
                },
                {
                  title: 'Essenzielle Cookies',
                  description:
                    'Diese Cookies sind f\u00fcr die Funktion der Website unbedingt erforderlich und k\u00f6nnen nicht deaktiviert werden.',
                  linkedCategory: 'necessary',
                },
                {
                  title: 'Analyse-Cookies',
                  description:
                    'Diese Cookies helfen uns zu verstehen, wie Besucher mit unserer Website interagieren, indem sie anonyme Nutzungsdaten erheben. Wir verwenden hierf\u00fcr Google Analytics.',
                  linkedCategory: 'analytics',
                },
                {
                  title: 'Weitere Informationen',
                  description:
                    'Bei Fragen zu unserer Cookie-Richtlinie <a href="/de/contact" class="cc-link">kontaktieren Sie uns</a> gerne.',
                },
              ],
            },
          },

          es: {
            consentModal: {
              title: 'Respetamos tu privacidad',
              description:
                'Usamos cookies para analizar el uso del sitio y mejorar tu experiencia. Pod\u00e9s aceptar o rechazar las cookies no esenciales a continuaci\u00f3n. <a href="/es/privacy" class="cc-link">Pol\u00edtica de Privacidad</a>',
              acceptAllBtn: 'Aceptar todo',
              acceptNecessaryBtn: 'Rechazar todo',
              showPreferencesBtn: 'Gestionar preferencias',
            },
            preferencesModal: {
              title: 'Preferencias de Cookies',
              acceptAllBtn: 'Aceptar todo',
              acceptNecessaryBtn: 'Rechazar todo',
              savePreferencesBtn: 'Guardar preferencias',
              closeIconLabel: 'Cerrar',
              sections: [
                {
                  title: 'Uso de Cookies',
                  description:
                    'Usamos cookies para garantizar la funcionalidad b\u00e1sica de nuestro sitio web y mejorar tu experiencia. Pod\u00e9s elegir qu\u00e9 categor\u00edas aceptar en cualquier momento. Para m\u00e1s detalles, le\u00e9 nuestra <a href="/es/privacy" class="cc-link">Pol\u00edtica de Privacidad</a> y nuestro <a href="/es/impressum" class="cc-link">Aviso Legal</a>.',
                },
                {
                  title: 'Cookies Esenciales',
                  description:
                    'Estas cookies son estrictamente necesarias para que el sitio web funcione y no se pueden desactivar.',
                  linkedCategory: 'necessary',
                },
                {
                  title: 'Cookies de An\u00e1lisis',
                  description:
                    'Estas cookies nos ayudan a entender c\u00f3mo los visitantes interact\u00faan con nuestro sitio web, recopilando datos de uso an\u00f3nimos. Utilizamos Google Analytics con este prop\u00f3sito.',
                  linkedCategory: 'analytics',
                },
                {
                  title: 'M\u00e1s Informaci\u00f3n',
                  description:
                    'Si ten\u00e9s preguntas sobre nuestra pol\u00edtica de cookies, <a href="/es/contact" class="cc-link">contactanos</a>.',
                },
              ],
            },
          },
        },
      },
    });
  }
</script>

<!-- Custom overrides for boutique agency aesthetic -->
<style is:global>
  :root {
    --cc-bg: #ffffff;
    --cc-primary-color: #111111;
    --cc-secondary-color: #64748b;

    --cc-btn-primary-bg: #111111;
    --cc-btn-primary-color: #ffffff;
    --cc-btn-primary-border-color: #111111;
    --cc-btn-primary-hover-bg: #333333;
    --cc-btn-primary-hover-color: #ffffff;
    --cc-btn-primary-hover-border-color: #333333;

    --cc-btn-secondary-bg: #ffffff;
    --cc-btn-secondary-color: #111111;
    --cc-btn-secondary-border-color: #111111;
    --cc-btn-secondary-hover-bg: #f1f5f9;
    --cc-btn-secondary-hover-color: #111111;
    --cc-btn-secondary-hover-border-color: #111111;

    --cc-separator-border-color: #e2e8f0;
    --cc-cookie-category-block-bg: #f8fafc;
    --cc-cookie-category-block-border: #e2e8f0;

    --cc-toggle-on-bg: #111111;
    --cc-toggle-off-bg: #cbd5e1;
    --cc-toggle-readonly-bg: #94a3b8;

    --cc-overlay-bg: rgba(0, 0, 0, 0.45);
    --cc-font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }

  #cc-main .cm {
    border-radius: 16px !important;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.12) !important;
    border: 1px solid #e2e8f0 !important;
    max-width: 420px !important;
  }

  #cc-main .cm__title {
    font-size: 16px !important;
    font-weight: 600 !important;
  }

  #cc-main .cm__desc {
    font-size: 13px !important;
    line-height: 1.6 !important;
    color: #64748b !important;
  }

  #cc-main .cm__btn {
    border-radius: 9999px !important;
    font-size: 13px !important;
    font-weight: 600 !important;
    padding: 10px 22px !important;
    transition: background 0.2s ease, transform 0.15s ease !important;
  }

  #cc-main .cm__btn:hover {
    transform: scale(1.02);
  }

  #cc-main .pm {
    border-radius: 16px !important;
    box-shadow: 0 16px 64px rgba(0, 0, 0, 0.15) !important;
  }

  #cc-main .pm__title {
    font-size: 18px !important;
    font-weight: 600 !important;
  }

  #cc-main .pm__btn {
    border-radius: 9999px !important;
    font-size: 13px !important;
    font-weight: 600 !important;
  }

  #cc-main .cc-link {
    color: #111111 !important;
    text-decoration: underline !important;
    text-decoration-color: #cbd5e1 !important;
    transition: text-decoration-color 0.2s ease !important;
  }

  #cc-main .cc-link:hover {
    text-decoration-color: #111111 !important;
  }

  @media (max-width: 640px) {
    #cc-main .cm {
      max-width: 100% !important;
      border-radius: 16px 16px 0 0 !important;
      margin: 0 !important;
    }
  }
</style>
