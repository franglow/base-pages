---
const { data } = Astro.props;
---

<section class="border-t border-gray-200 bg-gray-50/50">
  <div class="max-w-7xl mx-auto px-6 py-6 md:py-8 flex flex-col md:flex-row items-center justify-between gap-4 text-center md:text-left">
    
    <p class="text-gray-500 text-sm md:text-base">
      <span class="text-gray-900 font-semibold tracking-wide uppercase text-xs mr-2 px-2 py-1 bg-gray-200 rounded-md">
        {data.prefix}
      </span>
      {data.text}
    </p>

    <a 
      href={data.url} 
      class="text-sm font-semibold text-gray-900 hover:text-blue-600 transition-colors flex items-center gap-1 group whitespace-nowrap"
    >
      {data.linkText} 
      <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
    </a>
    
  </div>
</section>