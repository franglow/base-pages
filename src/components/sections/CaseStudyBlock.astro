---
import caseStudyPlaceholder from '../../assets/case-studies/placeholder.svg';

interface HeadlineMetric {
  value: string;
  label: string;
}

interface Props {
  clientName: string;
  industry: string;
  headlineMetric: HeadlineMetric;
  challenge: string;
  outcome: string;
  quote?: string;
  quoteAttribution?: string;
  imageUrl?: string;
  imageAlt?: string;
  projectUrl?: string;
  class?: string;
}

const {
  clientName,
  industry,
  headlineMetric,
  challenge,
  outcome,
  quote,
  quoteAttribution,
  imageUrl,
  imageAlt,
  projectUrl,
  class: className,
} = Astro.props;

const resolvedImage = imageUrl ?? caseStudyPlaceholder.src;
const resolvedAlt = imageAlt ?? `${clientName} — project screenshot`;
const slug = clientName.replace(/\s+/g, '-').toLowerCase();
---

<article
  aria-labelledby={`case-study-${slug}`}
  class:list={[
    'case-study-block',
    'grid grid-cols-1 md:grid-cols-5',
    'gap-6 md:gap-10',
    'items-center',
    'max-w-5xl mx-auto',
    'rounded-2xl',
    'border border-gray-200/60',
    'bg-white',
    'p-5 md:p-8',
    'shadow-[0_4px_24px_rgba(0,0,0,0.04)]',
    className,
  ]}
>
  <figure class="md:col-span-2 m-0">
    <img
      src={resolvedImage}
      alt={resolvedAlt}
      width="800"
      height="600"
      loading="lazy"
      decoding="async"
      class="w-full h-auto rounded-xl object-cover ring-1 ring-gray-200/60"
    />
  </figure>

  <div class="md:col-span-3 flex flex-col gap-4 min-w-0">
    <p class="text-[11px] font-mono font-bold tracking-[0.18em] uppercase text-gray-500 m-0">
      {industry}
    </p>

    <div class="flex items-baseline gap-3 flex-wrap">
      <span
        class="text-4xl md:text-5xl font-semibold leading-none tracking-tight text-gray-900"
      >
        {headlineMetric.value}
      </span>
      <span class="text-sm md:text-base text-gray-600">
        {headlineMetric.label}
      </span>
    </div>

    <h3
      id={`case-study-${slug}`}
      class="text-xl md:text-2xl font-semibold leading-snug text-gray-900 m-0"
    >
      {outcome}
    </h3>

    <p class="text-sm md:text-[15px] leading-relaxed text-gray-600 m-0">
      <span class="font-semibold text-gray-700">The challenge:</span>{' '}{challenge}
    </p>

    {quote && (
      <blockquote
        cite={`#case-study-${slug}`}
        class="border-l-2 border-gray-300 pl-4 m-0 font-serif text-[15px] italic leading-relaxed text-gray-700"
      >
        “{quote}”
        {quoteAttribution && (
          <footer class="not-italic text-xs text-gray-500 mt-2 font-sans">
            — {quoteAttribution}
          </footer>
        )}
      </blockquote>
    )}

    <p class="text-xs text-gray-500 m-0">
      <span class="font-medium text-gray-700">{clientName}</span>
      {projectUrl && (
        <>
          {' · '}
          <a
            href={projectUrl}
            class="text-gray-700 underline underline-offset-4 decoration-gray-300 hover:decoration-gray-700 transition-colors"
          >
            See the project →
          </a>
        </>
      )}
    </p>
  </div>
</article>
