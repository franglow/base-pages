---
interface Props {
  eyebrow?: string;
  headline: string;
  subtitle?: string;
  emailLabel?: string;
  emailPlaceholder?: string;
  buttonText?: string;
  successMessage?: string;
  privacyNote?: string;
  tier: 'starter' | 'growth' | 'scale' | 'care' | 'partnership';
  pdfHref: string;
  lang?: 'en' | 'es' | 'de';
  class?: string;
}

const {
  eyebrow,
  headline,
  subtitle,
  emailLabel = 'Your email',
  emailPlaceholder = 'you@company.com',
  buttonText = 'Send me the one-pager',
  successMessage = 'Sent. Check your inbox — including spam, just in case.',
  privacyNote,
  tier,
  pdfHref,
  lang = 'en',
  class: className = '',
} = Astro.props;

const formId = `soft-cta-${tier}`;
---

<section class:list={['soft-cta', className]} aria-labelledby={`${formId}-heading`}>
  <div class="container">
    <div class="soft-cta-card">
      <div class="soft-cta-copy">
        {eyebrow && <p class="soft-cta-eyebrow">{eyebrow}</p>}
        <h2 id={`${formId}-heading`} class="soft-cta-headline">{headline}</h2>
        {subtitle && <p class="soft-cta-subtitle">{subtitle}</p>}
      </div>

      <form
        id={formId}
        class="soft-cta-form"
        data-soft-cta
        data-tier={tier}
        data-lang={lang}
        data-pdf-href={pdfHref}
        data-success-message={successMessage}
        novalidate
      >
        <div class="soft-cta-row">
          <label for={`${formId}-email`} class="visually-hidden">{emailLabel}</label>
          <input
            id={`${formId}-email`}
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder={emailPlaceholder}
            class="soft-cta-input"
            aria-describedby={`${formId}-status`}
          />
          <button type="submit" class="soft-cta-btn">
            <span class="soft-cta-btn-label">{buttonText}</span>
            <span class="soft-cta-btn-spinner" aria-hidden="true"></span>
          </button>
        </div>

        <p id={`${formId}-status`} class="soft-cta-status" role="status" aria-live="polite"></p>

        {privacyNote && (
          <p class="soft-cta-privacy">
            {privacyNote} ·{' '}
            <a href={pdfHref} class="soft-cta-direct" download>Or just download it →</a>
          </p>
        )}
      </form>
    </div>
  </div>
</section>

<style>
  .soft-cta {
    padding: 40px 0 60px;
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .soft-cta-card {
    background: #111827;
    color: #ffffff;
    border-radius: 24px;
    padding: 40px 28px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .soft-cta-eyebrow {
    margin: 0 0 12px;
    font-family: 'Roboto Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .soft-cta-headline {
    margin: 0 0 12px;
    font-size: 26px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 500;
    color: #ffffff;
  }

  .soft-cta-subtitle {
    margin: 0;
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    max-width: 48ch;
  }

  .soft-cta-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .soft-cta-row {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .soft-cta-input {
    width: 100%;
    box-sizing: border-box;
    padding: 14px 18px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.06);
    color: #ffffff;
    font-size: 15px;
    line-height: 1.3;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .soft-cta-input::placeholder {
    color: rgba(255, 255, 255, 0.45);
  }

  .soft-cta-input:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.1);
  }

  .soft-cta-input:invalid:not(:placeholder-shown) {
    border-color: rgba(248, 113, 113, 0.55);
  }

  .soft-cta-btn {
    position: relative;
    appearance: none;
    border: 0;
    background: #ffffff;
    color: #111827;
    font-size: 15px;
    font-weight: 500;
    padding: 14px 22px;
    border-radius: 14px;
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    white-space: nowrap;
  }

  .soft-cta-btn:hover {
    transform: translateY(-1px);
  }

  .soft-cta-btn[disabled] {
    opacity: 0.7;
    cursor: progress;
    transform: none;
  }

  .soft-cta-btn-spinner {
    display: none;
    width: 14px;
    height: 14px;
    border: 2px solid rgba(17, 24, 39, 0.25);
    border-top-color: #111827;
    border-radius: 50%;
    animation: soft-cta-spin 0.8s linear infinite;
  }

  .soft-cta-btn[data-loading='true'] .soft-cta-btn-spinner {
    display: inline-block;
  }

  @keyframes soft-cta-spin {
    to { transform: rotate(360deg); }
  }

  .soft-cta-status {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.75);
    min-height: 1.25em;
  }

  .soft-cta-status[data-variant='success'] {
    color: #86efac;
  }

  .soft-cta-status[data-variant='error'] {
    color: #fca5a5;
  }

  .soft-cta-privacy {
    margin: 0;
    font-size: 13px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.45);
  }

  .soft-cta-direct {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .soft-cta-direct:hover {
    color: #ffffff;
  }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 768px) {
    .soft-cta {
      padding: 56px 0 80px;
    }
    .soft-cta-card {
      padding: 56px 48px;
      flex-direction: row;
      align-items: center;
      gap: 56px;
    }
    .soft-cta-copy {
      flex: 1 1 50%;
    }
    .soft-cta-form {
      flex: 1 1 50%;
    }
    .soft-cta-headline {
      font-size: 30px;
    }
    .soft-cta-row {
      flex-direction: row;
      align-items: stretch;
    }
    .soft-cta-input {
      flex: 1 1 auto;
      min-width: 0;
    }
  }
</style>

<script>
  function initSoftCTA() {
    const forms = document.querySelectorAll<HTMLFormElement>('form[data-soft-cta]');
    forms.forEach((form) => {
      if (form.dataset.softCtaBound === '1') return;
      form.dataset.softCtaBound = '1';

      const status = form.querySelector<HTMLElement>('.soft-cta-status');
      const button = form.querySelector<HTMLButtonElement>('.soft-cta-btn');
      const input = form.querySelector<HTMLInputElement>('.soft-cta-input');

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!input || !button || !status) return;

        if (!input.checkValidity()) {
          status.dataset.variant = 'error';
          status.textContent = 'Please enter a valid email.';
          input.focus();
          return;
        }

        const tier = form.dataset.tier || 'starter';
        const lang = form.dataset.lang || 'en';
        const pdfHref = form.dataset.pdfHref || '';
        const successMessage =
          form.dataset.successMessage ||
          'Sent. Check your inbox — including spam, just in case.';

        const formData = new FormData();
        formData.set('email', input.value);
        formData.set('tier', tier);
        formData.set('lang', lang);

        button.setAttribute('data-loading', 'true');
        button.disabled = true;
        status.removeAttribute('data-variant');
        status.textContent = '';

        try {
          const res = await fetch('/_actions/captureEmail', {
            method: 'POST',
            body: formData,
            headers: { Accept: 'application/json' },
          });

          if (!res.ok) {
            throw new Error(`HTTP ${res.status}`);
          }

          const payload = await res.json().catch(() => null);
          const didSucceed =
            (payload && (payload.data?.success || payload.success)) || res.status < 300;

          if (!didSucceed) {
            throw new Error('Capture failed');
          }

          status.dataset.variant = 'success';
          status.textContent = successMessage;
          input.value = '';
          input.blur();
        } catch (err) {
          console.error('[SoftCTA] capture failed', err);
          status.dataset.variant = 'error';
          status.textContent =
            'Something went wrong. You can still download it directly → ' + pdfHref;
        } finally {
          button.removeAttribute('data-loading');
          button.disabled = false;
        }
      });
    });
  }

  initSoftCTA();
  document.addEventListener('astro:page-load', initSoftCTA);
</script>
