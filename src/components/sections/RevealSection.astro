---
// src/components/sections/RevealSection.astro
import { Picture } from 'astro:assets';
import revealBg from '../../assets/images/reveal-section/reveal-image-01.jpg'; 
---

<section class="reveal-container">
  <div class="scroll-indicator">
    KEEP SCROLLING
  </div>
  <div class="pin-wrapper">
    <div class="content-wrapper">
      <h2 class="side-text left-text">Base</h2>

      <div class="expanding-box">
        
        <Picture 
          src={revealBg} 
          alt="Work Preview" 
          widths={[400, 768, 1200, 1920]} 
          sizes="(max-width: 767px) 100vw, (max-width: 1023px) 100vw, 100vw"
          formats={['avif', 'webp']} 
          fallbackFormat="webp"
          loading="eager" 
          fetchpriority="high"
          decoding="async"
        />

        <div class="overlay-text">
          <p>foundations for <br class="mobile-break" /> high-performing</p>
        </div>
      </div>

      <h2 class="side-text right-text">Pages</h2>
    </div>
  </div>
</section>

<style>
  .reveal-container {
    position: relative;
    width: 100%;
    height: 400dvh; 
  }

  .scroll-indicator {
    position: absolute;
    top: 15dvh; 
    left: 0;
    width: 100%;
    text-align: center;
    color: #7a7a7a; 
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.35em; 
    z-index: 20;
  }

  .pin-wrapper {
    position: sticky; 
    top: 0;
    height: 100dvh; 
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .content-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(8px, 1.5vw, 16px); 
    width: 100%;
    height: 100dvh; 
    font-size: clamp(32px, 5vw, 56px);
  }

  .side-text {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 600;
    white-space: nowrap;
    margin: 0;
    line-height: 1;
    width: 50vw; 
    flex-shrink: 0;
  }
  
  .left-text {
    display: flex;
    justify-content: flex-end; 
  }

  .right-text {
    display: flex;
    justify-content: flex-start;
  }

  .expanding-box {
    position: relative;
    width: 0.4em;   
    height: 1.1em;  
    border-radius: 100px;
    overflow: hidden;
    flex-shrink: 0; 
    z-index: 5;
  }

  .expanding-box picture {
    display: contents;
  }

  .expanding-box img {
    width: 100vw;
    height: 100dvh;
    object-fit: cover;
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .overlay-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: max-content; 
    text-align: center;
  }

  .overlay-text p {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 600;
    color: white;
    margin: 0;
    white-space: normal; 
    line-height: 1.1; 
    text-align: center;
  }

  .mobile-break {
    display: block;
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .expanding-box {
      width: 90px;   
      height: 110px; 
      border-radius: 1rem; 
    }
    
    .overlay-text p {
      white-space: nowrap;
      line-height: 1;
    }
    .mobile-break {
      display: none; 
    }
  }

  @media (min-width: 1024px) {
    .expanding-box {
      width: 160px; 
      height: 90px; 
      border-radius: 1rem;
    }
    
    .overlay-text p {
      white-space: nowrap;
      line-height: 1;
    }
    .mobile-break {
      display: none; 
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let mm = gsap.matchMedia();

  mm.add({
    isMobile: "(max-width: 767px)",
    isDesktop: "(min-width: 768px)" 
  }, (context) => {
    
    let { isMobile } = context.conditions;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: ".reveal-container",
        start: "top top",
        end: "bottom bottom", 
        scrub: 1
      }
    });

    tl.to(".scroll-indicator", {
      opacity: 0, 
      duration: 0.15, 
      ease: "power1.inOut"
    }, 0)
    
    .to(".expanding-box", {
      width: isMobile ? "calc(100vw - 32px)" : "min(calc(100vw - 96px), 1280px)",
      height: isMobile ? "calc(100dvh - 48px)" : "calc(100dvh - 80px)",
      borderRadius: "16px",
      ease: "none"
    }, 0)

    .fromTo(".overlay-text", 
      {
        y: "20px",    
        opacity: 0    
      },
      {
        y: "0px",     
        opacity: 1,   
        ease: "power2.out", 
        duration: 0.5 
      }, 
    0); 

  }); 
</script>