---
// src/components/sections/RevealSection.astro

// 1. Import the Picture component
import { Picture } from 'astro:assets';

// 2. Import the local image from your src/assets folder
// IMPORTANT: Move the image file from /public/images/ to /src/assets/images/
import revealBg from '../../assets/images/reveal-section/reveal-image-01.jpg'; 
---

<section class="reveal-container">
  <div class="scroll-indicator">
    KEEP SCROLLING
  </div>
  <div class="pin-wrapper">
    <div class="content-wrapper">
      <h2 class="side-text left-text">Base</h2>

      <div class="expanding-box">
        
        <Picture 
          src={revealBg} 
          alt="Work Preview" 
          widths={[400, 768, 1200, 1920]} 
          sizes="(max-width: 767px) 100vw, (max-width: 1023px) 100vw, 100vw"
          formats={['avif', 'webp']} 
          fallbackFormat="webp"
          loading="eager" 
          fetchpriority="high"
          decoding="async"
        />

        <div class="overlay-text">
          <p>foundations for <br class="mobile-break" /> high-performing</p>
        </div>
      </div>

      <h2 class="side-text right-text">Pages</h2>
    </div>
  </div>
</section>

<style>
  .reveal-container {
    position: relative;
    width: 100%;
  }

  .scroll-indicator {
    position: absolute;
    top: 15vh; 
    left: 0;
    width: 100%;
    text-align: center;
    color: #7a7a7a; 
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.35em; 
    z-index: 20;
  }

  .pin-wrapper {
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .content-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(8px, 1.5vw, 16px); 
    width: 100%;
    height: 100vh;
    font-size: clamp(32px, 5vw, 56px);
  }

  .side-text {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 600;
    white-space: nowrap;
    margin: 0;
    line-height: 1;
    width: 50vw; 
    flex-shrink: 0;
  }
  
  .left-text {
    display: flex;
    justify-content: flex-end; 
  }

  .right-text {
    display: flex;
    justify-content: flex-start;
  }

  .expanding-box {
    position: relative;
    width: 0.4em;   
    height: 1.1em;  
    border-radius: 100px;
    overflow: hidden;
    flex-shrink: 0; 
    z-index: 5;
  }

  /* 🎯 NEW: Make the <picture> wrapper invisible to the layout engine */
  .expanding-box picture {
    display: contents;
  }

  .expanding-box img {
    width: 100vw;
    height: 100vh;
    object-fit: cover;
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .overlay-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: max-content; 
    text-align: center;
  }

  .overlay-text p {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 600;
    color: white;
    margin: 0;
    white-space: normal; 
    line-height: 1.1; 
    text-align: center;
  }

  .mobile-break {
    display: block;
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .expanding-box {
      width: 90px;   
      height: 110px; 
      border-radius: 1rem; 
    }
    
    .overlay-text p {
      white-space: nowrap;
      line-height: 1;
    }
    .mobile-break {
      display: none; 
    }
  }

  @media (min-width: 1024px) {
    .expanding-box {
      width: 160px; 
      height: 90px; 
      border-radius: 1rem;
    }
    
    .overlay-text p {
      white-space: nowrap;
      line-height: 1;
    }
    .mobile-break {
      display: none; 
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let mm = gsap.matchMedia();

  mm.add({
    isMobile: "(max-width: 767px)",
    isTablet: "(min-width: 768px) and (max-width: 1023px)", 
    isDesktop: "(min-width: 1024px)"
  }, (context) => {
    
    let { isMobile } = context.conditions;

    const textEl = document.querySelector('.side-text');
    const fSize = textEl ? parseFloat(window.getComputedStyle(textEl).fontSize) : 32;

    const startWidthNum = isMobile ? (fSize * 0.4) : 160; 
    const startWidth = `${startWidthNum}px`;
    
    const startHeightNum = isMobile ? (fSize * 1.1) : 90;
    const startHeight = `${startHeightNum}px`;
    
    const startRadius = isMobile ? "100px" : "16px"; 
    
    const destWidthNum = isMobile 
      ? window.innerWidth - 32 
      : Math.min(window.innerWidth - 96, 1280);
      
    const destHeightNum = isMobile 
      ? window.innerHeight - 48 
      : window.innerHeight - 80;

    const finalWidth = `${destWidthNum}px`;
    const finalHeight = `${destHeightNum}px`;
    const finalRadius = "16px";

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: ".reveal-container",
        start: "top top",
        end: "+=300%", 
        scrub: 2,
        pin: true,
        invalidateOnRefresh: true 
      }
    });

    tl.to(".scroll-indicator", {
      y: "-20vh", 
      opacity: 0, 
      ease: "power1.inOut"
    }, 0)
    
    .fromTo(".expanding-box", 
      {
        width: startWidth,
        height: startHeight,
        borderRadius: startRadius 
      },
      {
        width: finalWidth,       
        height: finalHeight,     
        borderRadius: finalRadius, 
        ease: "none" 
      }, 
    0)

    .fromTo(".overlay-text", 
      {
        y: "20px",    
        opacity: 0    
      },
      {
        y: "-0.5px",     
        opacity: 1,   
        ease: "power2.out", 
        duration: 0.5 
      }, 
    0); 

  }); 
</script>