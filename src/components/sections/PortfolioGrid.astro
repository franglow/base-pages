---
// src/components/sections/PortfolioGrid.astro
import { Image } from 'astro:assets';

// 1. Global loader for local images
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/**/*.{jpeg,jpg,png,gif,webp}');

interface Props {
  data?: any;
}
const { data } = Astro.props;

// Safely access the data
const projects = data?.projects || [];
const projectCount = projects.length;
---

<section class="work-section">
  <div class="container">
    <h2 class="section-title">{data?.title || 'Work'}
      <sup class="text-[14px] bg-gray-900 text-white rounded-full w-[20px] h-[20px] flex items-center justify-center font-semibold mt-2 md:mt-4">
        {projectCount}
      </sup>
    </h2>
    
    <div class="projects-grid">
      {projects.map((project: any) => (
        <article class="project-card">
          <div class="image-container">
            <a href={project.url} class="image-link">
              <div class="scroll-zoom-wrapper">
                <Image 
                  src={images[project.gridImg || project.image]()} 
                  class="main-img" 
                  alt={project.title} 
                />
              </div>
            </a>
          </div>
          
          <div class="project-info">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .work-section {
    padding: clamp(60px, 8vw, 100px) 24px;
    background-color: #f8f7f5;
    text-align: center;
  }

  .container {
    max-width: 1000px; 
    margin: 0 auto;
  }

  .section-title {
    font-family: 'Inter', sans-serif; 
    font-size: clamp(40px, 6vw, 64px); 
    font-weight: 500;
    letter-spacing: -2px;
    margin-bottom: clamp(32px, 6vw, 80px);
    display: inline-flex;
    align-items: flex-start;
    justify-content: center;
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: clamp(60px, 10vw, 120px); 
  }

  .project-card {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .image-container {
    position: relative;
    width: 100%;
    margin-bottom: clamp(24px, 4vw, 40px);
  }

  /* 🎯 EL CONTENEDOR PRINCIPAL (REFORZADO) */
  .image-link {
    display: block;
    position: relative;
    width: 100%;
    
    /* Restauramos y blindamos el radio */
    border-radius: 20px; 
    overflow: hidden; 
    
    /* Fix para Safari: Obliga a respetar el border-radius en animaciones */
    -webkit-mask-image: -webkit-radial-gradient(white, black);
    transform: translateZ(0); 
    
    background-color: #000;
  }

  /* ✨ EL TINTE AMBAR */
  .image-link::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg, 
      rgba(217, 119, 6, 0.3) 0%, 
      rgba(180, 83, 9, 0.15) 100%
    );
    mix-blend-mode: color;
    opacity: 1;
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 2;
    pointer-events: none;
    border-radius: 20px; /* Aseguramos radio también en el overlay */
  }

  /* ✨ LA CAPA DE CALIDEZ */
  .image-link::before {
    content: "";
    position: absolute;
    inset: 0;
    background-color: #78350f;
    mix-blend-mode: overlay;
    opacity: 0.15;
    z-index: 1;
    transition: opacity 0.7s ease;
    border-radius: 20px;
  }

  .scroll-zoom-wrapper {
    width: 100%;
    height: 100%;
    will-change: transform;
    z-index: 0;
  }

  .main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 16 / 9;
    display: block;
    filter: saturate(0.9); 
    transition: filter 0.7s ease;
    /* Extra seguridad para la imagen */
    border-radius: 20px; 
  }

  .image-link:hover .main-img {
    filter: saturate(1);
  }

  /* INFO DEL PROYECTO */
  .project-info h3 {
    font-size: clamp(16px, 4vw, 28px); 
    font-weight: 600;
    margin-bottom: 12px;
    color: #1a1a1a;
  }

  .project-info p {
    font-size: clamp(14px, 3vw, 20px); 
    color: #666666;
    max-width: 600px;
    line-height: 1.4;
    margin: 0 auto;
    font-weight: 400;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initPortfolioScrubZoom() {
    gsap.registerPlugin(ScrollTrigger);

    const cards = document.querySelectorAll('.project-card');

    cards.forEach((card) => {
      const wrapper = card.querySelector('.scroll-zoom-wrapper');

      gsap.fromTo(wrapper, 
        { scale: 1 }, 
        {
          scale: 1.15,
          ease: "none",
          scrollTrigger: {
            trigger: card,
            start: "top bottom", 
            end: "bottom top",   
            scrub: true 
          }
        }
      );
    });
  }

  initPortfolioScrubZoom();
  document.addEventListener('astro:page-load', initPortfolioScrubZoom);
</script>