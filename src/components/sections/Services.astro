---
import Button from '../ui/Button.astro';
const { data } = Astro.props;
---

<section id="services" class="max-w-7xl mx-auto px-6 py-24 md:py-32 scroll-mt-24">
  
  <div id="scroll-container" class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24 items-start relative">
    
    <div id="left-col" class="lg:col-span-7 lg:sticky lg:top-32">
      
      <div class="flex items-center gap-4 mb-8 md:mb-12">
        <div class="h-[2px] w-12 bg-[linear-gradient(90deg,#A8BFAF_0%,#E8DDC8_50%,#F6D7C8_100%)]"></div>
        <span class="text-sm font-bold tracking-widest uppercase text-gray-900">{data.tagline}</span>
      </div>
      
      <h2 id="reveal-text" class="text-[32px] md:text-[48px] lg:text-[56px] font-medium tracking-tight text-gray-900 lg:text-gray-300 leading-tight">
        {data.headline}
      </h2>
    </div>

    <div class="lg:col-span-5 flex flex-col gap-12 md:gap-20 lg:pt-24">
      {data.items.map((item: any, index: number) => (
        <article class="service-card observe-card flex flex-col gap-5">
          
          <a href={item.url} class="block rounded-[20px] overflow-hidden shadow-sm relative z-0 transform-gpu w-full max-w-[344px] md:max-w-[360px] lg:max-w-[402px] aspect-[1.5] group">
            
            <div class="service-img-wrapper w-full h-full will-change-transform bg-[#f8f7f5] flex items-center justify-center border border-gray-100 overflow-hidden">
              
              {/* SHAPE 1: THE STARTER (Squircle) */}
              {index === 0 && (
                <div class="w-32 h-32 md:w-40 md:h-40 rounded-[32px] md:rounded-[40px] brand-gradient shape-breath shadow-lg shadow-black/5" />
              )}

              {/* SHAPE 2: THE GROWTH (Pill) */}
              {index === 1 && (
                <div class="w-40 h-24 md:w-48 md:h-28 rounded-[40px] md:rounded-[48px] brand-gradient shape-tilt shadow-lg shadow-black/5" />
              )}

              {/* SHAPE 3: THE SCALE (Overlapping Squircles) */}
              {index === 2 && (
                <div class="relative w-32 h-32 md:w-40 md:h-40">
                  <div class="absolute inset-0 rounded-[32px] md:rounded-[40px] brand-gradient opacity-60 mix-blend-multiply shape-overlap-1" />
                  <div class="absolute inset-0 rounded-[32px] md:rounded-[40px] brand-gradient opacity-90 backdrop-blur-sm shape-overlap-2 shadow-lg shadow-black/5" />
                </div>
              )}

            </div>
          </a>

          <div>
            <h3 class="text-[16px] md:text-[18px] lg:text-[20px] font-semibold text-gray-900 transition-colors">
              {item.title}
            </h3>
            
            <p class="text-gray-500 text-[14px] md:text-base mt-2 mb-5">
              {item.description || item.subtitle}
              <a href={item.url} class="md:hidden group inline-flex items-center gap-1 text-gray-900 font-medium hover:text-gray-500 transition-colors ml-1 whitespace-nowrap">
                Explore package
                <svg class="w-3.5 h-3.5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </a>
            </p>
            
            <div class="flex flex-wrap items-center gap-4 mt-2">
              
              <div class="flex items-center gap-3">
                <span class="bg-gray-100 text-gray-800 px-3 py-1.5 rounded-full text-sm font-medium whitespace-nowrap">
                  {item.price}
                </span>
                <span class="text-gray-400 flex items-center gap-1.5 border border-gray-200 px-3 py-1.5 rounded-full text-sm font-medium whitespace-nowrap">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  {item.delivery}
                </span>
              </div>

              <a href={item.url} class="hidden md:inline-flex group items-center gap-1.5 text-gray-900 font-medium text-[15px] hover:text-gray-500 transition-colors">
                Explore package
                <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </a>
              
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

  <div class="mt-32 w-full grid grid-cols-1 lg:grid-cols-2 gap-0 items-stretch lg:h-[666.5px]">
    <div class="relative overflow-hidden rounded-[2rem] aspect-[2.5/1] lg:aspect-auto lg:h-full w-full bg-gray-200">
      <video 
        src="/continuos-care-02.mp4" 
        autoplay 
        loop 
        muted 
        playsinline 
        class="absolute inset-0 w-full h-full object-cover"
      ></video>
    </div>
    
    <div class="rounded-[2rem] bg-white p-8 md:p-12 lg:p-16 flex flex-col justify-between items-start shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100 lg:h-full">
      <div>
        <span class="inline-block bg-gray-100 text-gray-800 px-4 py-2 rounded-full text-[14px] font-medium mb-4">
          {data.cta.pill}
        </span>
        <h3 class="text-[24px] md:text-4xl lg:text-[32px] font-semibold text-gray-900 leading-tight max-w-lg tracking-tight">
          {data.cta.title}
        </h3>
      </div>

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 mt-12 md:mt-16 w-full">
        <Button href={data.cta.buttonUrl} class="shrink-0 bg-black text-white px-8 py-4 !rounded-2xl font-medium hover:scale-105 transition-transform shadow-lg">
          {data.cta.buttonText}
        </Button>
        <p class="text-gray-500 text-[14px] max-w-[280px] leading-relaxed">
          {data.cta.note}
        </p>
      </div>
    </div>
  </div>
</section>

<style is:global>
  #reveal-text .word {
    transition: color 0.15s ease-out;
  }
  #reveal-text .word.active {
    color: #111827; 
  }

  /* --- BRAND GRADIENT & GEOMETRY ANIMATIONS --- */
  
  .brand-gradient {
    background: linear-gradient(135deg, #A8BFAF 0%, #E8DDC8 50%, #F6D7C8 100%);
    background-size: 200% 200%;
    /* 🎯 FIX: Pausadas por defecto para cuidar la batería/GPU */
    animation: gradientShift 8s ease infinite paused;
  }

  /* 🎯 FIX: Se reproducen solo cuando están visibles en pantalla */
  .observe-card.is-in-view .brand-gradient {
    animation-play-state: running;
  }

  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* The Starter */
  .shape-breath {
    animation: breath 6s ease-in-out infinite paused;
  }
  .observe-card.is-in-view .shape-breath {
    animation-play-state: running;
  }
  @keyframes breath {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  /* The Growth */
  .shape-tilt {
    transform: rotate(-35deg);
    animation: tilt 8s ease-in-out infinite paused;
  }
  .observe-card.is-in-view .shape-tilt {
    animation-play-state: running;
  }
  @keyframes tilt {
    0%, 100% { transform: rotate(-35deg) scale(1); }
    50% { transform: rotate(-25deg) scale(1.03); }
  }

  /* The Scale */
  .shape-overlap-1 {
    animation: overlap1 6s ease-in-out infinite paused;
  }
  .observe-card.is-in-view .shape-overlap-1 {
    animation-play-state: running;
  }
  .shape-overlap-2 {
    animation: overlap2 6s ease-in-out infinite paused;
  }
  .observe-card.is-in-view .shape-overlap-2 {
    animation-play-state: running;
  }
  @keyframes overlap1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-12px, -12px) scale(1.02); }
  }
  @keyframes overlap2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(12px, 12px) scale(0.98); }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initAll() {
    gsap.registerPlugin(ScrollTrigger);

    // --- 1. OBSERVERS (Para rendimiento de CSS en móviles) ---
    const observerOptions = {
      root: null,
      rootMargin: "0px",
      threshold: 0.1 // Se activa cuando el 10% de la tarjeta es visible
    };

    const cardObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-in-view');
        } else {
          entry.target.classList.remove('is-in-view');
        }
      });
    }, observerOptions);

    const cards = document.querySelectorAll('.observe-card');
    cards.forEach(card => cardObserver.observe(card));

    // --- 2. GSAP SCROLL TRIGGERS (Aislados solo para Desktop) ---
    let mm = gsap.matchMedia();

    // Solo se ejecuta en pantallas de computadora (>1024px)
    mm.add("(min-width: 1024px)", () => {
      
      // A. Animación del texto sticky pintándose
      const textElement = document.getElementById('reveal-text');
      const container = document.getElementById('scroll-container');
      const leftCol = document.getElementById('left-col');

      if (textElement && container && leftCol) {
        if (!textElement.hasAttribute('data-split')) {
          const text = textElement.innerText;
          const words = text.split(' ');
          textElement.innerHTML = '';

          words.forEach(word => {
            const span = document.createElement('span');
            span.innerText = word + ' ';
            span.classList.add('word');
            textElement.appendChild(span);
          });
          textElement.setAttribute('data-split', 'true');
        }

        const wordSpans = document.querySelectorAll('#reveal-text .word');

        ScrollTrigger.create({
          trigger: container,
          start: "top top+=128", 
          end: () => `+=${container.offsetHeight - leftCol.offsetHeight}`,
          onUpdate: (self) => {
            const wordsToHighlight = Math.floor(self.progress * wordSpans.length);
            wordSpans.forEach((span, index) => {
              if (index < wordsToHighlight) {
                span.classList.add('active');
              } else {
                span.classList.remove('active');
              }
            });
          }
        });
      }

      // B. Efecto Zoom (Scrub) en las imágenes
      const serviceCards = document.querySelectorAll('.service-card');

      serviceCards.forEach((card) => {
        const wrapper = card.querySelector('.service-img-wrapper');

        gsap.fromTo(wrapper, 
          { scale: 1 }, 
          {
            scale: 1.15, 
            ease: "none",
            scrollTrigger: {
              trigger: card,
              start: "top bottom", 
              end: "bottom top",   
              scrub: true 
            }
          }
        );
      });
      
    }); // Fin del bloque Desktop
  }

  initAll();
  document.addEventListener('astro:page-load', initAll);
</script>