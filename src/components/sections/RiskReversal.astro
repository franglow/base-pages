---
interface Point {
  label: string;
  detail: string;
}

interface Props {
  title?: string;
  points: Point[];
  class?: string;
}

const { title, points, class: className } = Astro.props;
const hasPoints = Array.isArray(points) && points.length > 0;
---

{hasPoints && (
  <section
    class:list={['risk-reversal', className]}
    aria-labelledby={title ? 'risk-reversal-title' : undefined}
  >
    <div class="rr-container">
      {title && (
        <h2 id="risk-reversal-title" class="rr-title">
          {title}
        </h2>
      )}
      <ul class="rr-grid" data-count={points.length}>
        {points.map((p) => (
          <li class="rr-point">
            <svg
              class="rr-check"
              aria-hidden="true"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.25"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
            <div class="rr-body">
              <p class="rr-label">{p.label}</p>
              <p class="rr-detail">{p.detail}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}

<style>
  .risk-reversal {
    padding: 32px 24px 48px;
    background: #ffffff;
  }

  .rr-container {
    max-width: 1120px;
    margin: 0 auto;
  }

  .rr-title {
    margin: 0 0 28px;
    text-align: center;
    font-size: clamp(18px, 2.2vw, 22px);
    font-weight: 500;
    letter-spacing: -0.2px;
    color: #111827;
  }

  .rr-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .rr-point {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 12px;
    align-items: start;
    padding: 18px 20px;
    border: 1px solid #e8e3d9;
    border-radius: 14px;
    background: #f8f7f5;
  }

  .rr-check {
    color: #065f46;
    margin-top: 2px;
    flex-shrink: 0;
  }

  .rr-body {
    min-width: 0;
  }

  .rr-label {
    margin: 0 0 4px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.1px;
    color: #111827;
    line-height: 1.35;
  }

  .rr-detail {
    margin: 0;
    font-size: 13px;
    color: #6b7280;
    line-height: 1.55;
  }

  @media (min-width: 900px) {
    .risk-reversal {
      padding: 56px 40px 72px;
    }

    .rr-grid[data-count='3'] {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .rr-grid[data-count='2'] {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      max-width: 760px;
      margin: 0 auto;
    }
  }
</style>
