---
// src/components/sections/Hero.astro
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';

interface Props {
  data: any;
}

const { data } = Astro.props;
const heroImagesGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/hero/*.{jpeg,jpg,png,gif,webp}');
const heroImages = await Promise.all(
  Object.keys(heroImagesGlob).map((key) => heroImagesGlob[key]().then(res => res.default))
);
---

<section class="hero-section relative w-full overflow-hidden flex flex-col items-center justify-center mt-[var(--header-height)] pt-[var(--header-height)]">

  <div class="orbit-container absolute top-1/2 left-1/2 w-0 h-0 z-0">
    {heroImages.map((img, index) => (
      <div class="orbit-item absolute top-0 left-0 w-0 h-0 will-change-transform">
        <div
          class="orbit-card"
          style={{
            animationDelay: `${index * 0.2}s`
          }}
        >
          <Image 
            src={img} 
            alt="" 
            width={220}
            class="w-full h-full object-cover" 
            loading="eager" 
          />
        </div>
      </div>
    ))}
  </div>

  <div class="hero-content relative z-30 text-center max-w-5xl w-full px-4 flex flex-col items-center -mt-16 max-[1000px]:landscape:mt-8">

      <div class="relative h-[90px] md:h-[220px] w-full overflow-hidden flex items-center justify-center mb-1 md:mb-6">
        <div class="h1-mask-container relative h-full w-full flex items-center justify-center">
          {data.titles.map((title: string) => (
            <h1 class="rotating-title absolute w-full max-w-[95%] md:max-w-[900px] lg:max-w-[600px] text-center text-[32px] md:text-[55px] lg:text-[55px] font-semibold tracking-tighter leading-[1.1] opacity-0">
              {title.split(" ").map((word: string) => (
                <span class="inline-block translate-y-[120%] opacity-0 py-1 md:py-2 mr-[0.2em]">{word}</span>
              ))}
            </h1>
          ))}
        </div>
      </div>

      <p class="text-[16px] md:text-[18px] text-[var(--color-text-muted)] font-medium max-w-lg text-balance mx-auto px-2 -mt-2 md:mt-0 mb-6 md:mb-8">
        {data.subtitle}
      </p>

      <div>
        <Button href={data.ctaUrl || "#services"} class="bg-black text-white px-8 py-4 !rounded-2xl hover:scale-105 transition-transform shadow-lg">
          {data.cta}
        </Button>
      </div>
    </div>
</section>

<style>
/* 0. LOCKED VIEWPORT HEIGHTS */
.hero-section {
  min-height: calc(var(--vh, 1svh) * 90);
}
@media (min-width: 768px) {
  .hero-section {
    min-height: calc(var(--vh, 1svh) * 100);
  }
  .hero-content {
    margin-top: calc(var(--vh, 1svh) * -12);
  }
}

/* 1. CARTAS ORBIT */
.orbit-card {
  width: 66.7px;   
  height: 86.7px;  
  transform: translate(-50%, -50%);
  border-radius: 0.6rem; 
  overflow: hidden;
  box-shadow: 0 8px 20px rgba(0,0,0,0.12);
  animation: flip-domino 10s infinite ease-in-out;
  backface-visibility: visible;
}

@media (min-width: 768px) {
  .orbit-card {
    width: 110px;
    height: 144px;
    border-radius: 1rem;
    box-shadow: 0 20px 40px rgba(0,0,0,0.25);
  }

  .h1-mask-container {
    height: 220px; 
  }
}

/* 3. CONTENEDOR DE TÍTULO */
.h1-mask-container {
  height: 110px; 
  position: relative;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rotating-title {
  display: block; 
  text-wrap: balance;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  position: absolute;
}

.rotating-title span {
  display: inline-block;
  will-change: transform, opacity;
  padding: 0 0.05em; 
}

/* 4. KEYFRAMES */
@keyframes flip-domino {
  0%, 30% { transform: translate(-50%, -50%) perspective(1000px) rotateY(0deg); }
  40% { transform: translate(-50%, -50%) perspective(1000px) rotateY(180deg); }
  40%, 90% { transform: translate(-50%, -50%) perspective(1000px) rotateY(180deg); }
  100% { transform: translate(-50%, -50%) perspective(1000px) rotateY(0deg); }
}

.hero-content-wrapper {
  position: relative;
  z-index: 30;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -2rem; 
}

@media (min-width: 768px) {
  .hero-content-wrapper {
    margin-top: -2vh;
  }
}
</style>

<script>
  import { gsap } from "gsap";

  const DURATION = 150;
  const MOBILE_BREAKPOINT = 768;

  let timeline = null;

  // Cache the initial viewport height so the orbit radius never shifts
  // when mobile browser chrome appears/disappears.
  const cachedHeight = Math.max(window.innerHeight, 700);

  const getRadiusVH = () => window.innerWidth < MOBILE_BREAKPOINT ? 29.5 : 41.8;

  function initHero() {
    const container = document.querySelector('.orbit-container');
    const items = document.querySelectorAll('.orbit-item');
    if (!container || !items.length) return;

    const radiusPx = (cachedHeight * getRadiusVH()) / 100;
    
    const angleStep = 360 / items.length;
    const progress = timeline?.progress() || 0;

    timeline?.kill();

    items.forEach((item, i) => {
      const rad = (i * angleStep * Math.PI) / 180;
      gsap.set(item, {
        x: radiusPx * Math.cos(rad),
        y: radiusPx * Math.sin(rad),
      });
    });

    timeline = gsap.timeline({ repeat: -1, defaults: { ease: "none" } })
      .to(container, { rotation: 360, duration: DURATION }, 0)
      .to(items, { rotation: -360, duration: DURATION }, 0)
      .progress(progress);
  }

  function initTitleRotation() {
    const titles = document.querySelectorAll('.rotating-title');
    if (!titles.length) return;

    const masterTl = gsap.timeline({ repeat: -1 });

    titles.forEach((title) => {
      const words = title.querySelectorAll('span');
      const tl = gsap.timeline();

      tl.set(title, { opacity: 1 }) 
        .to(words, { y: "0%", opacity: 1, duration: 0.8, ease: "back.out(2.5)", stagger: 0.08 })
        .to(words, { y: "-120%", opacity: 0, duration: 0.6, ease: "back.in(1.5)", stagger: 0.05, delay: 2.5 })
        .set(title, { opacity: 0 });

      masterTl.add(tl);
    });
  }

  initHero();
  initTitleRotation();

  let resizeTimer;
  let currentWidth = window.innerWidth;

  window.addEventListener("resize", () => {
    if (window.innerWidth !== currentWidth) {
      currentWidth = window.innerWidth;
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(initHero, 200);
    }
  });
</script>