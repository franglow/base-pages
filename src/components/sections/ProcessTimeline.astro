---
interface Step {
  title: string;
  description: string;
  owner: string;
  duration: string;
  ownerTone?: 'you' | 'me' | 'together';
}

interface Props {
  sectionTagline?: string;
  sectionHeadline?: string;
  steps: Step[];
  class?: string;
}

const {
  sectionTagline,
  sectionHeadline,
  steps,
  class: className,
} = Astro.props;

const hasSteps = Array.isArray(steps) && steps.length > 0;
const stepCount = hasSteps ? steps.length : 0;
---

{hasSteps && (
  <section
    class:list={['process-timeline', className]}
    aria-labelledby="process-timeline-title"
    data-step-count={stepCount}
  >
    <div class="pt-container">
      {(sectionTagline || sectionHeadline) && (
        <header class="pt-header">
          {sectionTagline && <p class="pt-tagline">{sectionTagline}</p>}
          {sectionHeadline && (
            <h2 id="process-timeline-title" class="pt-headline">
              {sectionHeadline}
            </h2>
          )}
        </header>
      )}

      <ol class="pt-steps" data-count={stepCount}>
        {steps.map((step, idx) => (
          <li class="pt-step">
            <div class="pt-num-wrap">
              <span class="pt-num" aria-hidden="true">{idx + 1}</span>
              {idx < stepCount - 1 && <span class="pt-connector" aria-hidden="true" />}
            </div>
            <div class="pt-body">
              <h3 class="pt-title">{step.title}</h3>
              <p class="pt-desc">{step.description}</p>
              <div class="pt-badges">
                <span
                  class:list={['pt-badge', 'pt-owner', `pt-owner-${step.ownerTone ?? 'me'}`]}
                >
                  {step.owner}
                </span>
                <span class="pt-badge pt-duration">{step.duration}</span>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>
)}

<style>
  .process-timeline {
    padding: 40px 24px 64px;
    background: #ffffff;
  }

  .pt-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .pt-header {
    text-align: center;
    margin: 0 0 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  .pt-tagline {
    margin: 0;
    font-family: 'Roboto Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    color: #9ca3af;
    text-transform: uppercase;
  }

  .pt-headline {
    margin: 0;
    font-size: clamp(24px, 3.5vw, 36px);
    font-weight: 500;
    letter-spacing: -0.8px;
    color: #111827;
    line-height: 1.2;
    max-width: 640px;
  }

  .pt-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .pt-step {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 16px;
    align-items: start;
  }

  .pt-num-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }

  .pt-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #111827;
    color: #ffffff;
    font-family: 'Roboto Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    flex-shrink: 0;
  }

  .pt-connector {
    display: block;
    width: 2px;
    flex: 1;
    min-height: 24px;
    background: linear-gradient(
      to bottom,
      #d1d5db 0%,
      #d1d5db 60%,
      transparent 100%
    );
    margin-top: 8px;
  }

  .pt-body {
    min-width: 0;
    padding-bottom: 4px;
  }

  .pt-title {
    margin: 0 0 6px;
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.2px;
    color: #111827;
    line-height: 1.3;
  }

  .pt-desc {
    margin: 0 0 12px;
    font-size: 14px;
    color: #6b7280;
    line-height: 1.6;
  }

  .pt-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .pt-badge {
    display: inline-flex;
    align-items: center;
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 999px;
    line-height: 1;
  }

  .pt-owner-you {
    background: #fef3c7;
    color: #92400e;
  }

  .pt-owner-me {
    background: #111827;
    color: #ffffff;
  }

  .pt-owner-together {
    background: #dbeafe;
    color: #1e3a8a;
  }

  .pt-duration {
    background: #f4f1ea;
    color: #4b5563;
    border: 1px solid #e8e3d9;
  }

  @media (min-width: 900px) {
    .process-timeline {
      padding: 72px 40px 104px;
    }

    .pt-header {
      margin-bottom: 56px;
      gap: 16px;
    }

    .pt-steps {
      flex-direction: row;
      gap: 0;
    }

    .pt-step {
      flex: 1;
      grid-template-columns: 1fr;
      gap: 16px;
      position: relative;
      padding: 0 12px;
    }

    .pt-num-wrap {
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      height: auto;
      gap: 0;
    }

    .pt-connector {
      width: auto;
      height: 2px;
      min-height: 0;
      flex: 1;
      margin-top: 0;
      margin-left: 12px;
      background: linear-gradient(
        to right,
        #d1d5db 0%,
        #d1d5db 85%,
        transparent 100%
      );
    }

    .pt-body {
      padding-bottom: 0;
    }

    .pt-title {
      font-size: 18px;
    }
  }
</style>
