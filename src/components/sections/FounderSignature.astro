---
import founderJpg from '../../assets/team/fran.jpg';
import founderWebp from '../../assets/team/fran.webp';

interface Props {
  name: string;
  role: string;
  message: string;
  avatarUrl?: string;
  avatarAlt?: string;
  class?: string;
}

const {
  name,
  role,
  message,
  avatarUrl,
  avatarAlt,
  class: className,
} = Astro.props;

const resolvedAvatar = avatarUrl ?? founderJpg.src;
const resolvedWebp = founderWebp.src;
const resolvedAlt = avatarAlt ?? `Portrait of ${name}, ${role}`;
---

<figure
  class:list={[
    'founder-signature',
    'flex items-start gap-4',
    'max-w-xl mx-auto',
    'rounded-2xl',
    'border border-gray-200/50',
    'bg-white',
    'p-5 md:p-6',
    'shadow-[0_4px_20px_rgba(0,0,0,0.03)]',
    className,
  ]}
>
  <picture class="h-14 w-14 shrink-0 overflow-hidden rounded-full ring-1 ring-gray-200/60">
    <source srcset={resolvedWebp} type="image/webp" />
    <img
      src={resolvedAvatar}
      alt={resolvedAlt}
      width="56"
      height="56"
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover"
    />
  </picture>
  <figcaption class="flex min-w-0 flex-col gap-1">
    <p class="text-sm font-semibold leading-tight text-gray-900">
      <span>{name}</span>
      <span class="ml-1 font-normal text-gray-500">· {role}</span>
    </p>
    <blockquote
      cite={`#founder-${name.replace(/\s+/g, '-').toLowerCase()}`}
      class="font-serif text-[15px] italic leading-relaxed text-gray-700"
    >
      “{message}”
    </blockquote>
  </figcaption>
</figure>
