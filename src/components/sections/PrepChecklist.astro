---
interface ChecklistItem {
  label: string;
  detail?: string;
}

interface Props {
  title: string;
  items: ChecklistItem[];
  class?: string;
}

const { title, items, class: className } = Astro.props;
---

<aside
  class:list={['prep-checklist', className]}
  aria-labelledby="prep-checklist-title"
>
  <h3 id="prep-checklist-title" class="pc-title">{title}</h3>
  <ol class="pc-list">
    {items.map((item, idx) => (
      <li class="pc-item">
        <span class="pc-num" aria-hidden="true">{idx + 1}</span>
        <div class="pc-body">
          <p class="pc-label">{item.label}</p>
          {item.detail && <p class="pc-detail">{item.detail}</p>}
        </div>
      </li>
    ))}
  </ol>
</aside>

<style>
  .prep-checklist {
    max-width: 560px;
    margin: 0 auto;
    padding: 24px 24px 28px;
    background: #f4f1ea;
    border-radius: 16px;
    border: 1px solid rgba(0, 0, 0, 0.04);
  }

  .pc-title {
    margin: 0 0 16px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.2px;
    color: #111827;
  }

  .pc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    counter-reset: prep;
  }

  .pc-item {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 12px;
    align-items: start;
  }

  .pc-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #e8e3d9;
    color: #4b5563;
    font-size: 13px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .pc-body {
    min-width: 0;
  }

  .pc-label {
    margin: 0;
    font-size: 14px;
    font-weight: 500;
    color: #1f2937;
    line-height: 1.45;
  }

  .pc-detail {
    margin: 4px 0 0;
    font-size: 13px;
    color: #6b7280;
    line-height: 1.55;
  }

  @media (min-width: 768px) {
    .prep-checklist {
      padding: 28px 32px 32px;
    }

    .pc-title {
      font-size: 16px;
      margin-bottom: 20px;
    }

    .pc-list {
      gap: 16px;
    }
  }
</style>
