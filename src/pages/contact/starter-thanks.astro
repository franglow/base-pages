---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/sections/Header.astro';
import Footer from '../../components/sections/Footer.astro';
import Button from '../../components/ui/Button.astro';

import enData from '../../i18n/en.json';

const { nav, footer } = enData;
---

<Layout title="Thank You! | Base Pages">
  <Header navData={nav} />

  <main class="bg-[#f8f7f5] min-h-screen flex flex-col justify-center">
    <div class="w-full max-w-2xl mx-auto px-6 pt-40 pb-32 text-center">
      
      <div class="mb-6">
        <div class="w-16 h-16 bg-emerald-50 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        <span class="font-['Roboto_Mono',_monospace] font-bold tracking-widest uppercase text-[13px] text-emerald-600">
          MESSAGE RECEIVED
        </span>
      </div>
      
      <h1 class="text-[40px] md:text-[56px] font-medium text-gray-900 mb-6 tracking-tight leading-tight">
        Thank you!
      </h1>
      
      <p class="text-gray-500 text-lg mb-12 max-w-md mx-auto leading-relaxed">
        We've received your message and you'll hear from us within 24 hours. Check your inbox for a confirmation email.
      </p>

      <Button href="/" class="bg-gray-900 text-white px-8 py-3 !rounded-2xl font-medium hover:scale-105 transition-transform shadow-sm">
        Back to Home
      </Button>
      
    </div>
  </main>

  <Footer data={footer} />
</Layout>
