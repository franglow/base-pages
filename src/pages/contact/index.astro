---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import Header from '../../components/sections/Header.astro';
import Footer from '../../components/sections/Footer.astro';
import { actions } from 'astro:actions';

import enData from '../../i18n/en.json';
import { generateHreflangLinks } from '../../i18n/hreflang';
import { getOrganizationSchema, getBreadcrumbSchema } from '../../utils/schema';

export const prerender = false;

const { nav, footer, contactPage } = enData;
const hreflangLinks = generateHreflangLinks('/contact', 'https://base-pages.com');
const jsonLd = [
  getOrganizationSchema(),
  getBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Contact', url: '/contact' },
  ]),
];

const result = Astro.getActionResult(actions.submitContact);
const inputErrors = result?.error?.fields;
const success = result?.data?.success;

const growth = contactPage.form.growth;
const scale = contactPage.form.scale;
const partnership = contactPage.form.partnership;
const care = contactPage.form.care;
---

<Layout
  title="Contact | base-pages — Let's Build Your Engine"
  description="Ready to launch your high-performance website? Get in touch for a free consultation. Expert Astro development with premium design."
  canonicalUrl="https://base-pages.com/contact"
  lang="en"
  hreflangLinks={hreflangLinks}
  jsonLd={jsonLd}
>
  
  <Header navData={nav} />

  <main class="contact-page bg-[#f8f7f5] min-h-screen flex flex-col justify-center">
    <div class="w-full max-w-2xl mx-auto px-6 pt-40 pb-32">
      
      {success ? (
        <div class="text-center py-16" role="status" aria-live="polite">
          <h1 class="text-[48px] md:text-[64px] font-medium text-gray-900 mb-6 tracking-tight">Thank you!</h1>
          <p class="text-lg text-gray-600 max-w-md mx-auto">We've received your message and will get back to you within 24 hours.</p>
        </div>
      ) : (
        <>
          <h1 class="text-[48px] md:text-[64px] font-medium text-gray-900 mb-12 tracking-tight">
            {contactPage.title}
          </h1>

          <form method="POST" action={actions.submitContact} class="flex flex-col gap-8">
            <input type="hidden" name="lang" value="en" />
            
            <div class="input-group">
              <label for="name" class="sr-only">{contactPage.form.namePlaceholder}</label>
              <input type="text" id="name" name="name" placeholder={contactPage.form.namePlaceholder} required class="minimal-input" aria-describedby={inputErrors?.name ? 'name-error' : undefined} />
              {inputErrors?.name && <p id="name-error" class="error-text" role="alert">{inputErrors.name}</p>}
            </div>

            <div class="input-group">
              <label for="email" class="sr-only">{contactPage.form.emailPlaceholder}</label>
              <input type="email" id="email" name="email" placeholder={contactPage.form.emailPlaceholder} required class="minimal-input" aria-describedby={inputErrors?.email ? 'email-error' : undefined} />
              {inputErrors?.email && <p id="email-error" class="error-text" role="alert">{inputErrors.email}</p>}
            </div>

            <div class="input-group relative">
              <label for="interest" class="sr-only">{contactPage.form.interestLabel}</label>
              <select id="interest" name="interest" required class="minimal-input appearance-none bg-transparent cursor-pointer" aria-describedby={inputErrors?.interest ? 'interest-error' : undefined}>
                <option value="" disabled selected hidden>{contactPage.form.interestLabel}</option>
                {contactPage.form.interests.map((interest: string) => (
                  <option value={interest} class="text-gray-900">{interest}</option>
                ))}
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/>
                </svg>
              </div>
              {inputErrors?.interest && <p id="interest-error" class="error-text" role="alert">{inputErrors.interest}</p>}
            </div>

            <!-- Growth Package Qualification Fields -->
            <div id="growth-fields" class="tier-fields">
              <p class="tier-section-label">{growth.sectionLabel}</p>
              <div class="tier-inner">
                <div class="input-group">
                  <input type="url" id="websiteUrl" name="websiteUrl" placeholder={growth.websitePlaceholder} class="minimal-input" />
                </div>
                <div class="input-group relative">
                  <select id="adSpend" name="adSpend" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected hidden>{growth.adSpendLabel}</option>
                    {growth.adSpendOptions.map((opt: string) => (<option value={opt} class="text-gray-900">{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <fieldset class="chips-fieldset">
                  <legend class="chips-legend">{growth.channelsLabel}</legend>
                  <div class="chips-grid">
                    {growth.channels.map((ch: string) => (
                      <label class="chip"><input type="checkbox" name="channelOption" value={ch} class="chip-checkbox channel-checkbox" /><span class="chip-label">{ch}</span></label>
                    ))}
                  </div>
                </fieldset>
                <div class="input-group relative">
                  <select id="conversionGoal" name="conversionGoal" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected hidden>{growth.goalLabel}</option>
                    {growth.goals.map((g: string) => (<option value={g} class="text-gray-900">{g}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
              </div>
            </div>

            <!-- Scale Package Briefing Fields -->
            <div id="scale-fields" class="tier-fields">
              <p class="tier-section-label">{scale.sectionLabel}</p>
              <div class="tier-inner">
                <div class="input-group relative">
                  <select id="cmsPreference" name="cmsPreference" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected hidden>{scale.cmsLabel}</option>
                    {scale.cmsOptions.map((opt: string) => (<option value={opt} class="text-gray-900">{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <div class="input-group relative">
                  <select id="pageScope" name="pageScope" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected hidden>{scale.pageScopeLabel}</option>
                    {scale.pageScopeOptions.map((opt: string) => (<option value={opt} class="text-gray-900">{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <fieldset class="chips-fieldset">
                  <legend class="chips-legend">{scale.featuresLabel}</legend>
                  <div class="chips-grid">
                    {scale.features.map((f: string) => (
                      <label class="chip"><input type="checkbox" name="scaleFeatureOption" value={f} class="chip-checkbox scale-feature-checkbox" /><span class="chip-label">{f}</span></label>
                    ))}
                  </div>
                </fieldset>
                <div class="input-group relative">
                  <select id="launchTimeline" name="launchTimeline" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected hidden>{scale.timelineLabel}</option>
                    {scale.timelineOptions.map((opt: string) => (<option value={opt} class="text-gray-900">{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
              </div>
            </div>

            <!-- Partnership Vetting Fields -->
            <div id="partnership-fields" class="tier-fields">
              <p class="tier-section-label">{partnership.sectionLabel}</p>
              <div class="tier-inner">
                <div class="input-group">
                  <input type="url" id="portfolioUrl" name="portfolioUrl" placeholder={partnership.portfolioPlaceholder} class="minimal-input" />
                </div>
                <div class="input-group relative">
                  <select id="designTool" name="designTool" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected hidden>{partnership.designToolLabel}</option>
                    {partnership.designToolOptions.map((opt: string) => (<option value={opt} class="text-gray-900">{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <div class="input-group relative">
                  <select id="projectVolume" name="projectVolume" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected hidden>{partnership.projectVolumeLabel}</option>
                    {partnership.projectVolumeOptions.map((opt: string) => (<option value={opt} class="text-gray-900">{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <div class="input-group">
                  <input type="url" id="figmaSample" name="figmaSample" placeholder={partnership.figmaSamplePlaceholder} class="minimal-input" />
                </div>
              </div>
            </div>

            <!-- Continuous Care Fields -->
            <div id="care-fields" class="tier-fields">
              <p class="tier-section-label">{care.sectionLabel}</p>
              <div class="tier-inner">
                <div class="input-group">
                  <input type="url" id="careWebsiteUrl" name="careWebsiteUrl" placeholder={care.websitePlaceholder} class="minimal-input" />
                </div>
                <div class="input-group relative">
                  <select id="carePlatform" name="carePlatform" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected hidden>{care.platformLabel}</option>
                    {care.platformOptions.map((opt: string) => (<option value={opt} class="text-gray-900">{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <div class="input-group relative">
                  <select id="carePriority" name="carePriority" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected hidden>{care.priorityLabel}</option>
                    {care.priorityOptions.map((opt: string) => (<option value={opt} class="text-gray-900">{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <div class="input-group relative">
                  <select id="careOrigin" name="careOrigin" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected hidden>{care.originLabel}</option>
                    {care.originOptions.map((opt: string) => (<option value={opt} class="text-gray-900">{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
              </div>
            </div>

            <div class="input-group">
              <input type="text" id="budget" name="budget" placeholder={contactPage.form.budgetLabel} class="minimal-input" />
            </div>

            <div class="input-group">
              <textarea id="message" name="message" placeholder={contactPage.form.messagePlaceholder} required rows="1" class="minimal-input resize-none"></textarea>
              {inputErrors?.message && <p class="error-text">{inputErrors.message}</p>}
            </div>

            <Button type="submit" class="submit-btn w-full !px-6 !py-2.5 !rounded-2xl !text-sm mt-4">
              {contactPage.form.submitText}
            </Button>

          </form>
        </>
      )}
    </div>
  </main>

  <Footer data={footer} />

</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const interestSelect = document.getElementById('interest') as HTMLSelectElement | null;
    const growthFields = document.getElementById('growth-fields');
    const scaleFields = document.getElementById('scale-fields');
    const partnerFields = document.getElementById('partnership-fields');
    const careFields = document.getElementById('care-fields');
    if (!interestSelect || !growthFields || !scaleFields || !partnerFields || !careFields) return;

    function getSelectedTier(): 'growth' | 'scale' | 'partnership' | 'care' | null {
      const val = interestSelect!.value.toLowerCase();
      if (val.includes('growth')) return 'growth';
      if (val.includes('scale')) return 'scale';
      if (val.includes('partnership') || val.includes('white-label') || val.includes('marca blanca')) return 'partnership';
      if (val.includes('care') || val.includes('cuidado') || val.includes('betreuung')) return 'care';
      return null;
    }

    // ── Growth toggle ───────────────────────────────────────────────
    function showGrowth(): void {
      growthFields!.classList.add('tier-visible');
      growthFields!.querySelector<HTMLInputElement>('#websiteUrl')?.setAttribute('required', '');
      growthFields!.querySelector<HTMLSelectElement>('#adSpend')?.setAttribute('required', '');
      growthFields!.querySelector<HTMLSelectElement>('#conversionGoal')?.setAttribute('required', '');
    }
    function hideGrowth(): void {
      growthFields!.classList.remove('tier-visible');
      const wu = growthFields!.querySelector<HTMLInputElement>('#websiteUrl');
      const as = growthFields!.querySelector<HTMLSelectElement>('#adSpend');
      const cg = growthFields!.querySelector<HTMLSelectElement>('#conversionGoal');
      if (wu) { wu.removeAttribute('required'); wu.value = ''; }
      if (as) { as.removeAttribute('required'); as.selectedIndex = 0; }
      if (cg) { cg.removeAttribute('required'); cg.selectedIndex = 0; }
      growthFields!.querySelectorAll<HTMLInputElement>('.channel-checkbox').forEach(cb => cb.checked = false);
    }

    // ── Scale toggle ────────────────────────────────────────────────
    function showScale(): void {
      scaleFields!.classList.add('tier-visible');
      scaleFields!.querySelector<HTMLSelectElement>('#cmsPreference')?.setAttribute('required', '');
      scaleFields!.querySelector<HTMLSelectElement>('#pageScope')?.setAttribute('required', '');
      scaleFields!.querySelector<HTMLSelectElement>('#launchTimeline')?.setAttribute('required', '');
    }
    function hideScale(): void {
      scaleFields!.classList.remove('tier-visible');
      const cms = scaleFields!.querySelector<HTMLSelectElement>('#cmsPreference');
      const ps = scaleFields!.querySelector<HTMLSelectElement>('#pageScope');
      const lt = scaleFields!.querySelector<HTMLSelectElement>('#launchTimeline');
      if (cms) { cms.removeAttribute('required'); cms.selectedIndex = 0; }
      if (ps) { ps.removeAttribute('required'); ps.selectedIndex = 0; }
      if (lt) { lt.removeAttribute('required'); lt.selectedIndex = 0; }
      scaleFields!.querySelectorAll<HTMLInputElement>('.scale-feature-checkbox').forEach(cb => cb.checked = false);
    }

    // ── Partnership toggle ──────────────────────────────────────────
    function showPartnership(): void {
      partnerFields!.classList.add('tier-visible');
      partnerFields!.querySelector<HTMLInputElement>('#portfolioUrl')?.setAttribute('required', '');
      partnerFields!.querySelector<HTMLSelectElement>('#designTool')?.setAttribute('required', '');
      partnerFields!.querySelector<HTMLSelectElement>('#projectVolume')?.setAttribute('required', '');
    }
    function hidePartnership(): void {
      partnerFields!.classList.remove('tier-visible');
      const pu = partnerFields!.querySelector<HTMLInputElement>('#portfolioUrl');
      const dt = partnerFields!.querySelector<HTMLSelectElement>('#designTool');
      const pv = partnerFields!.querySelector<HTMLSelectElement>('#projectVolume');
      const fs = partnerFields!.querySelector<HTMLInputElement>('#figmaSample');
      if (pu) { pu.removeAttribute('required'); pu.value = ''; }
      if (dt) { dt.removeAttribute('required'); dt.selectedIndex = 0; }
      if (pv) { pv.removeAttribute('required'); pv.selectedIndex = 0; }
      if (fs) { fs.value = ''; }
    }

    // ── Care toggle ──────────────────────────────────────────────────
    function showCare(): void {
      careFields!.classList.add('tier-visible');
      careFields!.querySelector<HTMLInputElement>('#careWebsiteUrl')?.setAttribute('required', '');
      careFields!.querySelector<HTMLSelectElement>('#carePlatform')?.setAttribute('required', '');
      careFields!.querySelector<HTMLSelectElement>('#carePriority')?.setAttribute('required', '');
      careFields!.querySelector<HTMLSelectElement>('#careOrigin')?.setAttribute('required', '');
    }
    function hideCare(): void {
      careFields!.classList.remove('tier-visible');
      const cw = careFields!.querySelector<HTMLInputElement>('#careWebsiteUrl');
      const cp = careFields!.querySelector<HTMLSelectElement>('#carePlatform');
      const cpr = careFields!.querySelector<HTMLSelectElement>('#carePriority');
      const co = careFields!.querySelector<HTMLSelectElement>('#careOrigin');
      if (cw) { cw.removeAttribute('required'); cw.value = ''; }
      if (cp) { cp.removeAttribute('required'); cp.selectedIndex = 0; }
      if (cpr) { cpr.removeAttribute('required'); cpr.selectedIndex = 0; }
      if (co) { co.removeAttribute('required'); co.selectedIndex = 0; }
    }

    // ── Master toggle ───────────────────────────────────────────────
    function toggleTierFields(): void {
      const tier = getSelectedTier();
      tier === 'growth' ? showGrowth() : hideGrowth();
      tier === 'scale' ? showScale() : hideScale();
      tier === 'partnership' ? showPartnership() : hidePartnership();
      tier === 'care' ? showCare() : hideCare();
    }

    interestSelect.addEventListener('change', toggleTierFields);

    // Auto-select tier from ?tier= query param
    const urlParams = new URLSearchParams(window.location.search);
    const tierParam = urlParams.get('tier');
    if (tierParam === 'growth' || tierParam === 'scale' || tierParam === 'partnership' || tierParam === 'care' || tierParam === 'starter') {
      // Keywords to match localized option values per tier
      const tierKeywords: Record<string, string[]> = {
        starter: ['starter'],
        growth: ['growth'],
        scale: ['scale'],
        partnership: ['partnership', 'white-label', 'marca blanca', 'partnerschaft'],
        care: ['care', 'cuidado', 'betreuung'],
      };
      const keywords = tierKeywords[tierParam];
      const options = interestSelect.options;
      for (let i = 0; i < options.length; i++) {
        const val = options[i].value.toLowerCase();
        if (keywords.some(kw => val.includes(kw))) {
          interestSelect.selectedIndex = i;
          break;
        }
      }
      toggleTierFields();
    }
    
    // Merge checkboxes into hidden inputs on submit
    const form = interestSelect.closest('form');
    if (form) {
      const hiddenChannels = document.createElement('input');
      hiddenChannels.type = 'hidden'; hiddenChannels.name = 'channels'; hiddenChannels.id = 'channels-merged';
      form.appendChild(hiddenChannels);

      const hiddenScaleFeatures = document.createElement('input');
      hiddenScaleFeatures.type = 'hidden'; hiddenScaleFeatures.name = 'scaleFeatures'; hiddenScaleFeatures.id = 'scale-features-merged';
      form.appendChild(hiddenScaleFeatures);

      form.addEventListener('submit', () => {
        const checkedCh = growthFields!.querySelectorAll<HTMLInputElement>('.channel-checkbox:checked');
        hiddenChannels.value = Array.from(checkedCh).map(cb => cb.value).join(', ');
        growthFields!.querySelectorAll<HTMLInputElement>('.channel-checkbox').forEach(cb => cb.removeAttribute('name'));

        const checkedFt = scaleFields!.querySelectorAll<HTMLInputElement>('.scale-feature-checkbox:checked');
        hiddenScaleFeatures.value = Array.from(checkedFt).map(cb => cb.value).join(', ');
        scaleFields!.querySelectorAll<HTMLInputElement>('.scale-feature-checkbox').forEach(cb => cb.removeAttribute('name'));
      });
    }
  });
</script>

<style>
  .minimal-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid #111827;
    padding: 16px 0;
    font-size: 16px;
    color: #111827;
    outline: none;
    font-family: inherit;
    transition: border-color 0.3s ease, border-width 0.1s ease;
  }
  select.minimal-input:invalid { color: #111827; opacity: 1; }
  .minimal-input::placeholder { color: #111827; font-weight: 400; opacity: 1; }
  .minimal-input:focus { border-bottom-width: 2px; border-bottom-color: #000; margin-bottom: -1px; }

  .submit-btn {
    background-color: #111827; color: #fff; width: 100%; padding: 20px;
    border-radius: 999px; font-size: 16px; font-weight: 500; cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.4);
  }
  .submit-btn:hover { transform: translateY(-2px); box-shadow: 0 25px 45px -10px rgba(0,0,0,0.5); }

  .error-text { color: #dc2626; font-size: 14px; margin-top: 4px; }

  /* ── Tier Progressive Disclosure (shared) ─────────────────────────── */
  .tier-fields {
    max-height: 0; overflow: hidden; opacity: 0; margin: 0;
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease, margin 0.4s ease;
  }
  .tier-fields.tier-visible { max-height: 700px; opacity: 1; }
  .tier-section-label {
    font-size: 13px; font-weight: 500; text-transform: uppercase;
    letter-spacing: 0.08em; color: #6b7280; margin-bottom: 24px; padding-top: 8px;
  }
  .tier-inner { display: flex; flex-direction: column; gap: 32px; }

  /* ── Chip Checkboxes ──────────────────────────────────────────────── */
  .chips-fieldset { border: none; padding: 0; margin: 0; }
  .chips-legend { font-size: 16px; color: #111827; font-weight: 400; margin-bottom: 12px; display: block; }
  .chips-grid { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip { display: inline-flex; cursor: pointer; }
  .chip-checkbox { position: absolute; opacity: 0; pointer-events: none; }
  .chip-label {
    display: inline-block; padding: 8px 16px; border: 1px solid #d1d5db;
    border-radius: 999px; font-size: 14px; color: #374151;
    background: transparent; transition: all 0.2s ease; user-select: none;
  }
  .chip-checkbox:checked + .chip-label { background: #111827; color: #fff; border-color: #111827; }
  .chip-label:hover { border-color: #111827; }
</style>