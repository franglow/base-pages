---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import Header from '../../components/sections/Header.astro';
import Footer from '../../components/sections/Footer.astro';
import CalEmbed from '../../components/CalEmbed.astro';
import FounderVideo from '../../components/sections/FounderVideo.astro';
import PrepChecklist from '../../components/sections/PrepChecklist.astro';
import RelatedWorks from '../../components/sections/RelatedWorks.astro';
import { actions } from 'astro:actions';

import enData from '../../i18n/en.json';
import { generateHreflangLinks } from '../../i18n/hreflang';
import { getOrganizationSchema, getBreadcrumbSchema } from '../../utils/schema';

export const prerender = false;

const { nav, footer, contactPage } = enData;
const hreflangLinks = generateHreflangLinks('/contact', 'https://base-pages.com');
const jsonLd = [
  getOrganizationSchema(),
  getBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Contact', url: '/contact' },
  ]),
];

const result = Astro.getActionResult(actions.submitContact);
const inputErrors = result?.error?.fields;

// On success, redirect with type + pre-fill params (PRG pattern)
if (result?.data?.success) {
  const params = new URLSearchParams({ success: '1' });
  if (result.data.calType) params.set('type', result.data.calType);
  if (result.data.leadName) params.set('name', result.data.leadName);
  if (result.data.leadEmail) params.set('email', result.data.leadEmail);
  return Astro.redirect(`/contact?${params.toString()}`);
}

// Read success state + pre-fill data from URL (after redirect)
const success = Astro.url.searchParams.get('success') === '1';
const calType = Astro.url.searchParams.get('type'); // 'scale' | 'partnership' | null
const leadName = Astro.url.searchParams.get('name') || undefined;
const leadEmail = Astro.url.searchParams.get('email') || undefined;

// Capture action-level errors (non-field errors like Resend failures)
const actionError = result?.error && !inputErrors
  ? result.error.message || 'Something went wrong. Please try again.'
  : null;

const growth = contactPage.form.growth;
const scale = contactPage.form.scale;
const partnership = contactPage.form.partnership;
const care = contactPage.form.care;
const step1Copy = (contactPage.form as any).step1;
const step2Copy = (contactPage.form as any).step2;

const successData = (contactPage as any).success;
const founderVideo = successData.founderVideo;
const prepChecklistScale = successData.prepChecklist?.scale;
const prepChecklistPartnership = successData.prepChecklist?.partnership;
const relatedWorks = successData.relatedWorks;

const formPayload = Astro.locals.formPayload || {};
---

<Layout
  title="Contact | base-pages — Let's Build Your Engine"
  description="Ready to launch your high-performance website? Get in touch for a free consultation. Expert Astro development with premium design."
  canonicalUrl="https://base-pages.com/contact"
  lang="en"
  hreflangLinks={hreflangLinks}
  jsonLd={jsonLd}
>
  
  <Header navData={nav} />

  <main class="contact-page bg-[#f8f7f5] min-h-screen flex flex-col justify-center">
    <div class="w-full max-w-2xl mx-auto px-6 pt-40 pb-32">
      
      {success ? (
        <div class="text-center" role="status" aria-live="polite">
          <div class="mb-6">
            <span class="font-['Roboto_Mono',_monospace] font-bold tracking-widest uppercase text-[13px] text-emerald-600">
              {(contactPage as any).success.badge}
            </span>
          </div>

          {calType === 'scale' ? (
            <>
              <h1 class="text-[40px] md:text-[56px] font-medium text-gray-900 mb-6 tracking-tight leading-tight">
                {(contactPage as any).success.scaleHeading}
              </h1>
              <p class="text-gray-500 text-lg mb-10 max-w-md mx-auto">
                {(contactPage as any).success.scaleSubheading}
              </p>

              {founderVideo && (
                <div class="mb-8">
                  <FounderVideo
                    caption={founderVideo.caption}
                    placeholderLabel={founderVideo.placeholderLabel}
                  />
                </div>
              )}

              {prepChecklistScale && (
                <div class="mb-10">
                  <PrepChecklist
                    title={prepChecklistScale.title}
                    items={prepChecklistScale.items}
                  />
                </div>
              )}

              <CalEmbed
                namespace="scale-call"
                calLink="base-pages.com/scale-call"
                leadName={leadName}
                leadEmail={leadEmail}
                fallbackUrl="https://cal.com/base-pages.com/scale-call"
              />
              <p class="text-sm text-neutral-500 text-center mt-8 max-w-sm mx-auto leading-relaxed">
                {(contactPage as any).success.escapeRoute}{' '}
                <a href="/works" class="text-neutral-600 hover:text-black hover:underline transition-colors">{(contactPage as any).success.escapeWorks}</a>{' '}
                {(contactPage as any).success.escapeOr}{' '}
                <a href="/" class="text-neutral-600 hover:text-black hover:underline transition-colors">{(contactPage as any).success.escapeHome}</a>.
              </p>

              {relatedWorks && (
                <RelatedWorks
                  tagline={relatedWorks.tagline}
                  heading={relatedWorks.heading}
                  tier="scale"
                  works={relatedWorks.works}
                />
              )}
            </>
          ) : calType === 'partnership' ? (
            <>
              <h1 class="text-[40px] md:text-[56px] font-medium text-gray-900 mb-6 tracking-tight leading-tight">
                {(contactPage as any).success.partnershipHeading}
              </h1>
              <p class="text-gray-500 text-lg mb-10 max-w-md mx-auto">
                {(contactPage as any).success.partnershipSubheading}
              </p>

              {founderVideo && (
                <div class="mb-8">
                  <FounderVideo
                    caption={founderVideo.caption}
                    placeholderLabel={founderVideo.placeholderLabel}
                  />
                </div>
              )}

              {prepChecklistPartnership && (
                <div class="mb-10">
                  <PrepChecklist
                    title={prepChecklistPartnership.title}
                    items={prepChecklistPartnership.items}
                  />
                </div>
              )}

              <CalEmbed
                namespace="partnership-sync"
                calLink="base-pages.com/partnership-sync"
                leadName={leadName}
                leadEmail={leadEmail}
                fallbackUrl="https://cal.com/base-pages.com/partnership-sync"
              />
              <p class="text-sm text-neutral-500 text-center mt-8 max-w-sm mx-auto leading-relaxed">
                {(contactPage as any).success.escapeRoute}{' '}
                <a href="/works" class="text-neutral-600 hover:text-black hover:underline transition-colors">{(contactPage as any).success.escapeWorks}</a>{' '}
                {(contactPage as any).success.escapeOr}{' '}
                <a href="/" class="text-neutral-600 hover:text-black hover:underline transition-colors">{(contactPage as any).success.escapeHome}</a>.
              </p>

              {relatedWorks && (
                <RelatedWorks
                  tagline={relatedWorks.tagline}
                  heading={relatedWorks.heading}
                  tier="partnership"
                  works={relatedWorks.works}
                />
              )}
            </>
          ) : (
            <div class="py-8">
              <h1 class="text-[40px] md:text-[56px] font-medium text-gray-900 mb-6 tracking-tight leading-tight">
                {(contactPage as any).success.defaultHeading}
              </h1>
              <p class="text-neutral-500 text-lg max-w-md mx-auto">
                {(contactPage as any).success.defaultSubheading}
              </p>

              <div class="mt-16 mb-2">
                <p class="text-neutral-500 text-base max-w-md mx-auto mb-8">
                  {(contactPage as any).success.bridgeText}
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                  <a
                    href="/works"
                    class="inline-flex items-center justify-center px-8 py-3.5 bg-[#111827] text-white rounded-full text-sm font-medium transition-all hover:-translate-y-0.5 hover:shadow-lg"
                  >
                    {(contactPage as any).success.viewWorks}
                  </a>
                  <a
                    href="/"
                    class="inline-flex items-center justify-center px-8 py-3.5 bg-white text-[#111827] border border-gray-200 rounded-full text-sm font-medium transition-all hover:-translate-y-0.5 hover:border-[#111827]"
                  >
                    {(contactPage as any).success.backHome}
                  </a>
                </div>
              </div>

              {relatedWorks && (
                <RelatedWorks
                  tagline={relatedWorks.tagline}
                  heading={relatedWorks.heading}
                  tier="default"
                  works={relatedWorks.works}
                />
              )}
            </div>
          )}
        </div>
      ) : (
        <>
          <h1 class="text-[48px] md:text-[64px] font-medium text-gray-900 mb-12 tracking-tight">
            {contactPage.title}
          </h1>

          {actionError && (
            <div class="error-banner" role="alert">
              <p class="error-banner-title">⚠ Submission failed</p>
              <p class="error-banner-message">{actionError}</p>
            </div>
          )}

          <form method="POST" action={actions.submitContact} class="flex flex-col gap-8" data-two-step>
            <input type="hidden" name="lang" value="en" />
            <input type="hidden" name="step" value="2" id="step-input" />

            <div id="step-1" class="step-section" data-step="1">
              {step1Copy && (
                <header class="step-header">
                  <p class="step-eyebrow">{step1Copy.heading}</p>
                  {step1Copy.description && <p class="step-desc">{step1Copy.description}</p>}
                </header>
              )}

              <div class="input-group">
                <label for="name" class="field-label">{contactPage.form.namePlaceholder} <span class="text-neutral-400 ml-1" aria-hidden="true">*</span></label>
                <input type="text" id="name" name="name" placeholder={contactPage.form.namePlaceholder} required class="minimal-input" aria-describedby={inputErrors?.name ? 'name-error' : undefined} value={formPayload?.name || ''} />
                {inputErrors?.name && <p id="name-error" class="error-text" role="alert">{inputErrors.name}</p>}
              </div>

              <div class="input-group">
                <label for="email" class="field-label">{contactPage.form.emailPlaceholder} <span class="text-neutral-400 ml-1" aria-hidden="true">*</span></label>
                <input type="email" id="email" name="email" placeholder={contactPage.form.emailPlaceholder} required class="minimal-input" aria-describedby={inputErrors?.email ? 'email-error' : undefined} value={formPayload?.email || ''} />
                {inputErrors?.email && <p id="email-error" class="error-text" role="alert">{inputErrors.email}</p>}
              </div>

              <div class="input-group relative">
                <label for="interest" class="field-label">{contactPage.form.interestLabel} <span class="text-neutral-400 ml-1" aria-hidden="true">*</span></label>
                <select id="interest" name="interest" required class="minimal-input appearance-none bg-transparent cursor-pointer" aria-describedby={inputErrors?.interest ? 'interest-error' : undefined}>
                  <option value="" disabled selected={!formPayload?.interest} hidden>{contactPage.form.interestLabel}</option>
                  {contactPage.form.interests.map((interest: string) => (
                    <option value={interest} class="text-gray-900" selected={formPayload?.interest === interest}>{interest}</option>
                  ))}
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                  <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/>
                  </svg>
                </div>
                {inputErrors?.interest && <p id="interest-error" class="error-text" role="alert">{inputErrors.interest}</p>}
              </div>

              <button
                type="button"
                id="continue-btn"
                class="continue-btn submit-btn w-full px-6 py-2.5 rounded-2xl text-sm mt-2 inline-flex items-center justify-center font-medium cursor-pointer transition-colors"
              >
                {step1Copy?.continueText || 'Continue →'}
              </button>
            </div>

            <div
              id="step-2"
              class="step-section step-2"
              data-step="2"
              hidden
              data-desc-call={step2Copy?.description || ''}
              data-desc-quote={(step2Copy as any)?.descriptionQuote || step2Copy?.description || ''}
              data-skip-call={step2Copy?.skipText || ''}
              data-skip-quote={(step2Copy as any)?.skipTextQuote || step2Copy?.skipText || ''}
            >
              {step2Copy && (
                <header class="step-header step-2-header">
                  <p class="step-eyebrow">{step2Copy.heading}</p>
                  {step2Copy.description && <p class="step-desc" id="step-2-desc">{step2Copy.description}</p>}
                  <button type="button" id="skip-btn" class="skip-btn">
                    {step2Copy.skipText || 'Skip — book the call →'}
                  </button>
                </header>
              )}

            <!-- Growth Package Qualification Fields -->
            <div id="growth-fields" class="tier-fields" inert>
              <p class="tier-section-label">{growth.sectionLabel}</p>
              <div class="tier-inner">
                <div class="input-group">
                  <input type="url" id="websiteUrl" name="websiteUrl" placeholder={growth.websitePlaceholder} class="minimal-input" data-url-prefix value={formPayload?.websiteUrl || ''} />
                </div>
                <div class="input-group relative">
                  <select id="adSpend" name="adSpend" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected={!formPayload?.adSpend} hidden>{growth.adSpendLabel}</option>
                    {growth.adSpendOptions.map((opt: string) => (<option value={opt} class="text-gray-900" selected={formPayload?.adSpend === opt}>{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <fieldset class="chips-fieldset">
                  <legend class="chips-legend">{growth.channelsLabel}</legend>
                  <div class="chips-grid">
                    {growth.channels.map((ch: string) => (
                      <label class="chip"><input type="checkbox" value={ch} class="chip-checkbox channel-checkbox" checked={(formPayload?.channels || '').includes(ch)} /><span class="chip-label">{ch}</span></label>
                    ))}
                  </div>
                </fieldset>
                <div class="input-group relative">
                  <select id="conversionGoal" name="conversionGoal" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected={!formPayload?.conversionGoal} hidden>{growth.goalLabel}</option>
                    {growth.goals.map((g: string) => (<option value={g} class="text-gray-900" selected={formPayload?.conversionGoal === g}>{g}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
              </div>
            </div>

            <!-- Scale Package Briefing Fields -->
            <div id="scale-fields" class="tier-fields" inert>
              <p class="tier-section-label">{scale.sectionLabel}</p>
              <div class="tier-inner">
                <div class="input-group relative">
                  <select id="cmsPreference" name="cmsPreference" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected={!formPayload?.cmsPreference} hidden>{scale.cmsLabel}</option>
                    {scale.cmsOptions.map((opt: string) => (<option value={opt} class="text-gray-900" selected={formPayload?.cmsPreference === opt}>{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <div class="input-group relative">
                  <select id="pageScope" name="pageScope" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected={!formPayload?.pageScope} hidden>{scale.pageScopeLabel}</option>
                    {scale.pageScopeOptions.map((opt: string) => (<option value={opt} class="text-gray-900" selected={formPayload?.pageScope === opt}>{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <fieldset class="chips-fieldset">
                  <legend class="chips-legend">{scale.featuresLabel}</legend>
                  <div class="chips-grid">
                    {scale.features.map((f: string) => (
                      <label class="chip"><input type="checkbox" value={f} class="chip-checkbox scale-feature-checkbox" checked={(formPayload?.scaleFeatures || '').includes(f)} /><span class="chip-label">{f}</span></label>
                    ))}
                  </div>
                </fieldset>
                <div class="input-group relative">
                  <select id="launchTimeline" name="launchTimeline" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected={!formPayload?.launchTimeline} hidden>{scale.timelineLabel}</option>
                    {scale.timelineOptions.map((opt: string) => (<option value={opt} class="text-gray-900" selected={formPayload?.launchTimeline === opt}>{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
              </div>
            </div>

            <!-- Partnership Vetting Fields -->
            <div id="partnership-fields" class="tier-fields" inert>
              <p class="tier-section-label">{partnership.sectionLabel}</p>
              <div class="tier-inner">
                <div class="input-group">
                  <input type="url" id="portfolioUrl" name="portfolioUrl" placeholder={partnership.portfolioPlaceholder} class="minimal-input" data-url-prefix value={formPayload?.portfolioUrl || ''} />
                </div>
                <div class="input-group relative">
                  <select id="designTool" name="designTool" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected={!formPayload?.designTool} hidden>{partnership.designToolLabel}</option>
                    {partnership.designToolOptions.map((opt: string) => (<option value={opt} class="text-gray-900" selected={formPayload?.designTool === opt}>{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <div class="input-group relative">
                  <select id="projectVolume" name="projectVolume" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected={!formPayload?.projectVolume} hidden>{partnership.projectVolumeLabel}</option>
                    {partnership.projectVolumeOptions.map((opt: string) => (<option value={opt} class="text-gray-900" selected={formPayload?.projectVolume === opt}>{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <div class="input-group">
                  <input type="text" id="figmaSample" name="figmaSample" placeholder={partnership.figmaSamplePlaceholder} class="minimal-input" value={formPayload?.figmaSample || ''} />
                </div>
              </div>
            </div>

            <!-- Continuous Care Fields -->
            <div id="care-fields" class="tier-fields" inert>
              <p class="tier-section-label">{care.sectionLabel}</p>
              <div class="tier-inner">
                <div class="input-group">
                  <input type="url" id="careWebsiteUrl" name="careWebsiteUrl" placeholder={care.websitePlaceholder} class="minimal-input" data-url-prefix value={formPayload?.careWebsiteUrl || ''} />
                </div>
                <div class="input-group relative">
                  <select id="carePlatform" name="carePlatform" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected={!formPayload?.carePlatform} hidden>{care.platformLabel}</option>
                    {care.platformOptions.map((opt: string) => (<option value={opt} class="text-gray-900" selected={formPayload?.carePlatform === opt}>{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <div class="input-group relative">
                  <select id="carePriority" name="carePriority" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected={!formPayload?.carePriority} hidden>{care.priorityLabel}</option>
                    {care.priorityOptions.map((opt: string) => (<option value={opt} class="text-gray-900" selected={formPayload?.carePriority === opt}>{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
                <div class="input-group relative">
                  <select id="careOrigin" name="careOrigin" class="minimal-input appearance-none bg-transparent cursor-pointer">
                    <option value="" disabled selected={!formPayload?.careOrigin} hidden>{care.originLabel}</option>
                    {care.originOptions.map((opt: string) => (<option value={opt} class="text-gray-900" selected={formPayload?.careOrigin === opt}>{opt}</option>))}
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-900">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                  </div>
                </div>
              </div>
            </div>

            <div class="input-group">
              <label for="budget" class="field-label">{contactPage.form.budgetLabel} <span class="text-neutral-400 ml-1 text-sm" aria-hidden="true">(optional)</span></label>
              <input type="text" id="budget" name="budget" placeholder={contactPage.form.budgetLabel} class="minimal-input" value={formPayload?.budget || ''} />
            </div>

            <div class="input-group">
              <label for="message" class="field-label">{contactPage.form.messagePlaceholder}</label>
              <textarea id="message" name="message" placeholder={contactPage.form.messagePlaceholder} rows="1" class="minimal-input resize-none">{formPayload?.message || ''}</textarea>
              {inputErrors?.message && <p class="error-text">{inputErrors.message}</p>}
            </div>

            <Button type="submit" class="submit-btn w-full !px-6 !py-2.5 !rounded-2xl !text-sm mt-4">
              {contactPage.form.submitText}
            </Button>

            </div><!-- /#step-2 -->

          </form>
        </>
      )}
    </div>
  </main>

  <Footer data={footer} />

</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const interestSelect = document.getElementById('interest') as HTMLSelectElement | null;
    const growthFields = document.getElementById('growth-fields');
    const scaleFields = document.getElementById('scale-fields');
    const partnerFields = document.getElementById('partnership-fields');
    const careFields = document.getElementById('care-fields');
    if (!interestSelect || !growthFields || !scaleFields || !partnerFields || !careFields) return;

    function getSelectedTier(): 'growth' | 'scale' | 'partnership' | 'care' | null {
      const val = interestSelect!.value.toLowerCase();
      if (val.includes('growth')) return 'growth';
      if (val.includes('scale')) return 'scale';
      if (val.includes('partnership') || val.includes('white-label') || val.includes('marca blanca')) return 'partnership';
      if (val.includes('care') || val.includes('cuidado') || val.includes('betreuung')) return 'care';
      return null;
    }

    // Native `inert` removes the subtree from tab order, AT focus & clicks.
    // This is the correct replacement for tabindex="-1" hacks on hidden UI.
    function setInert(el: HTMLElement, on: boolean): void {
      if (on) el.setAttribute('inert', '');
      else el.removeAttribute('inert');
    }

    // ── Growth toggle ───────────────────────────────────────────────
    function showGrowth(): void {
      growthFields!.classList.add('tier-visible');
      setInert(growthFields!, false);
      growthFields!.querySelector<HTMLInputElement>('#websiteUrl')?.setAttribute('required', '');
      growthFields!.querySelector<HTMLSelectElement>('#adSpend')?.setAttribute('required', '');
      growthFields!.querySelector<HTMLSelectElement>('#conversionGoal')?.setAttribute('required', '');
    }
    function hideGrowth(): void {
      growthFields!.classList.remove('tier-visible');
      setInert(growthFields!, true);
      const wu = growthFields!.querySelector<HTMLInputElement>('#websiteUrl');
      const as = growthFields!.querySelector<HTMLSelectElement>('#adSpend');
      const cg = growthFields!.querySelector<HTMLSelectElement>('#conversionGoal');
      if (wu) { wu.removeAttribute('required'); wu.value = ''; }
      if (as) { as.removeAttribute('required'); as.selectedIndex = 0; }
      if (cg) { cg.removeAttribute('required'); cg.selectedIndex = 0; }
      growthFields!.querySelectorAll<HTMLInputElement>('.channel-checkbox').forEach(cb => cb.checked = false);
    }

    // ── Scale toggle ────────────────────────────────────────────────
    function showScale(): void {
      scaleFields!.classList.add('tier-visible');
      setInert(scaleFields!, false);
      scaleFields!.querySelector<HTMLSelectElement>('#cmsPreference')?.setAttribute('required', '');
      scaleFields!.querySelector<HTMLSelectElement>('#pageScope')?.setAttribute('required', '');
      scaleFields!.querySelector<HTMLSelectElement>('#launchTimeline')?.setAttribute('required', '');
    }
    function hideScale(): void {
      scaleFields!.classList.remove('tier-visible');
      setInert(scaleFields!, true);
      const cms = scaleFields!.querySelector<HTMLSelectElement>('#cmsPreference');
      const ps = scaleFields!.querySelector<HTMLSelectElement>('#pageScope');
      const lt = scaleFields!.querySelector<HTMLSelectElement>('#launchTimeline');
      if (cms) { cms.removeAttribute('required'); cms.selectedIndex = 0; }
      if (ps) { ps.removeAttribute('required'); ps.selectedIndex = 0; }
      if (lt) { lt.removeAttribute('required'); lt.selectedIndex = 0; }
      scaleFields!.querySelectorAll<HTMLInputElement>('.scale-feature-checkbox').forEach(cb => cb.checked = false);
    }

    // ── Partnership toggle ──────────────────────────────────────────
    function showPartnership(): void {
      partnerFields!.classList.add('tier-visible');
      setInert(partnerFields!, false);
      partnerFields!.querySelector<HTMLInputElement>('#portfolioUrl')?.setAttribute('required', '');
      partnerFields!.querySelector<HTMLSelectElement>('#designTool')?.setAttribute('required', '');
      partnerFields!.querySelector<HTMLSelectElement>('#projectVolume')?.setAttribute('required', '');
    }
    function hidePartnership(): void {
      partnerFields!.classList.remove('tier-visible');
      setInert(partnerFields!, true);
      const pu = partnerFields!.querySelector<HTMLInputElement>('#portfolioUrl');
      const dt = partnerFields!.querySelector<HTMLSelectElement>('#designTool');
      const pv = partnerFields!.querySelector<HTMLSelectElement>('#projectVolume');
      const fs = partnerFields!.querySelector<HTMLInputElement>('#figmaSample');
      if (pu) { pu.removeAttribute('required'); pu.value = ''; }
      if (dt) { dt.removeAttribute('required'); dt.selectedIndex = 0; }
      if (pv) { pv.removeAttribute('required'); pv.selectedIndex = 0; }
      if (fs) { fs.value = ''; }
    }

    // ── Care toggle ──────────────────────────────────────────────────
    function showCare(): void {
      careFields!.classList.add('tier-visible');
      setInert(careFields!, false);
      careFields!.querySelector<HTMLInputElement>('#careWebsiteUrl')?.setAttribute('required', '');
      careFields!.querySelector<HTMLSelectElement>('#carePlatform')?.setAttribute('required', '');
      careFields!.querySelector<HTMLSelectElement>('#carePriority')?.setAttribute('required', '');
      careFields!.querySelector<HTMLSelectElement>('#careOrigin')?.setAttribute('required', '');
    }
    function hideCare(): void {
      careFields!.classList.remove('tier-visible');
      setInert(careFields!, true);
      const cw = careFields!.querySelector<HTMLInputElement>('#careWebsiteUrl');
      const cp = careFields!.querySelector<HTMLSelectElement>('#carePlatform');
      const cpr = careFields!.querySelector<HTMLSelectElement>('#carePriority');
      const co = careFields!.querySelector<HTMLSelectElement>('#careOrigin');
      if (cw) { cw.removeAttribute('required'); cw.value = ''; }
      if (cp) { cp.removeAttribute('required'); cp.selectedIndex = 0; }
      if (cpr) { cpr.removeAttribute('required'); cpr.selectedIndex = 0; }
      if (co) { co.removeAttribute('required'); co.selectedIndex = 0; }
    }

    // ── Master toggle ───────────────────────────────────────────────
    function toggleTierFields(): void {
      const tier = getSelectedTier();
      tier === 'growth' ? showGrowth() : hideGrowth();
      tier === 'scale' ? showScale() : hideScale();
      tier === 'partnership' ? showPartnership() : hidePartnership();
      tier === 'care' ? showCare() : hideCare();
    }

    interestSelect.addEventListener('change', () => {
      toggleTierFields();
      // Keep Step 2 copy in sync if the user changes tier after revealing it.
      if (step2 && !step2.hasAttribute('hidden')) applyStep2CopyForTier();
    });

    // ── URL prefix normalizer (safe replacement for inline onblur regex) ─
    // Uses .startsWith() instead of a regex literal so production minifiers
    // can't collapse `\/\/` escapes into a `//` line-comment (which caused
    // "Uncaught SyntaxError: Unexpected end of input" on tab/blur).
    document.querySelectorAll<HTMLInputElement>('input[data-url-prefix]').forEach((el) => {
      el.addEventListener('blur', () => {
        const v = el.value.trim();
        if (!v) return;
        const lower = v.toLowerCase();
        if (!lower.startsWith('http://') && !lower.startsWith('https://')) {
          el.value = 'https://' + v;
        }
      });
    });

    // ── Two-step progressive disclosure ───────────────────────────
    const stepInput = document.getElementById('step-input') as HTMLInputElement | null;
    const step1 = document.getElementById('step-1');
    const step2 = document.getElementById('step-2');
    const continueBtn = document.getElementById('continue-btn') as HTMLButtonElement | null;
    const skipBtn = document.getElementById('skip-btn') as HTMLButtonElement | null;
    const nameInput = document.getElementById('name') as HTMLInputElement | null;
    const emailInput = document.getElementById('email') as HTMLInputElement | null;
    const messageInput = document.getElementById('message') as HTMLTextAreaElement | null;

    // Tiers that actually get a Cal.com booking on /contact?success; the rest
    // receive an async "message received → quote coming" flow, so the Step 2
    // copy must not promise a call.
    const CALL_TIERS = new Set(['scale', 'partnership']);

    function applyStep2CopyForTier(): void {
      if (!step2) return;
      const tier = getSelectedTier();
      const isCallTier = tier !== null && CALL_TIERS.has(tier);
      const descEl = document.getElementById('step-2-desc');
      if (descEl) {
        const next = isCallTier
          ? step2.getAttribute('data-desc-call') || ''
          : step2.getAttribute('data-desc-quote') || '';
        if (next) descEl.textContent = next;
      }
      if (skipBtn) {
        const next = isCallTier
          ? step2.getAttribute('data-skip-call') || ''
          : step2.getAttribute('data-skip-quote') || '';
        if (next) skipBtn.textContent = next;
      }
    }

    function revealStep2(): void {
      if (!step2) return;
      applyStep2CopyForTier();
      step2.removeAttribute('hidden');
      if (continueBtn) continueBtn.setAttribute('hidden', '');
      if (stepInput) stepInput.value = '2';
      requestAnimationFrame(() => step2.scrollIntoView({ behavior: 'smooth', block: 'start' }));
    }

    function validateStep1(): boolean {
      const fieldsToCheck: (HTMLInputElement | HTMLSelectElement | null)[] = [
        nameInput,
        emailInput,
        interestSelect,
      ];
      let firstInvalid: HTMLElement | null = null;
      fieldsToCheck.forEach((f) => {
        if (!f) return;
        if (!f.checkValidity()) {
          f.reportValidity();
          if (!firstInvalid) firstInvalid = f;
        }
      });
      return !firstInvalid;
    }

    continueBtn?.addEventListener('click', () => {
      if (validateStep1()) revealStep2();
    });

    skipBtn?.addEventListener('click', () => {
      if (!stepInput) return;
      stepInput.value = '1';
      // Strip any tier-fields `required` so browser doesn't block skip submit.
      document.querySelectorAll<HTMLElement>('.tier-fields [required]').forEach((el) => {
        el.removeAttribute('required');
      });
      // Clear the optional free-form message too.
      if (messageInput) messageInput.value = '';
      const nativeForm = skipBtn.closest('form') as HTMLFormElement | null;
      nativeForm?.submit();
    });

    // Auto-select tier from ?tier= query param
    const urlParams = new URLSearchParams(window.location.search);
    const tierParam = urlParams.get('tier');
    if (tierParam === 'growth' || tierParam === 'scale' || tierParam === 'partnership' || tierParam === 'care' || tierParam === 'starter') {
      // Keywords to match localized option values per tier
      const tierKeywords: Record<string, string[]> = {
        starter: ['starter'],
        growth: ['growth'],
        scale: ['scale'],
        partnership: ['partnership', 'white-label', 'marca blanca', 'partnerschaft'],
        care: ['care', 'cuidado', 'betreuung'],
      };
      const keywords = tierKeywords[tierParam];
      const options = interestSelect.options;
      for (let i = 0; i < options.length; i++) {
        const val = options[i].value.toLowerCase();
        if (keywords.some(kw => val.includes(kw))) {
          interestSelect.selectedIndex = i;
          break;
        }
      }
      toggleTierFields();
    }
    
    // Merge checkboxes into hidden inputs on submit
    const form = interestSelect.closest('form');
    if (form) {
      const hiddenChannels = document.createElement('input');
      hiddenChannels.type = 'hidden'; hiddenChannels.name = 'channels'; hiddenChannels.id = 'channels-merged';
      form.appendChild(hiddenChannels);

      const hiddenScaleFeatures = document.createElement('input');
      hiddenScaleFeatures.type = 'hidden'; hiddenScaleFeatures.name = 'scaleFeatures'; hiddenScaleFeatures.id = 'scale-features-merged';
      form.appendChild(hiddenScaleFeatures);

      form.addEventListener('submit', () => {
        const checkedCh = growthFields!.querySelectorAll<HTMLInputElement>('.channel-checkbox:checked');
        hiddenChannels.value = Array.from(checkedCh).map(cb => cb.value).join(', ');

        const checkedFt = scaleFields!.querySelectorAll<HTMLInputElement>('.scale-feature-checkbox:checked');
        hiddenScaleFeatures.value = Array.from(checkedFt).map(cb => cb.value).join(', ');
      });
    }
  });
</script>

