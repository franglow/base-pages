  /* ── Tier Progressive Disclosure (shared) ─────────────────────────── */
  .tier-fields {
    max-height: 0; overflow: hidden; opacity: 0; margin: 0;
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease, margin 0.4s ease;
  }
  .tier-fields.tier-visible { max-height: 700px; opacity: 1; }
  .tier-section-label {
    font-size: 13px; font-weight: 500; text-transform: uppercase;
