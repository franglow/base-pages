---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import Header from '../../components/sections/Header.astro';
import Footer from '../../components/sections/Footer.astro';
import { actions } from 'astro:actions';

import enData from '../../i18n/en.json';

const { nav, footer, contactPage } = enData;

const result = Astro.getActionResult(actions.submitStarter);
const inputErrors = result?.error?.fields;
const success = result?.data?.success;

if (success) {
  return Astro.redirect('/contact/starter-thanks');
}
---

<Layout title="Starter Package Contact | Base Pages">
  <Header navData={nav} />

  <main class="contact-page bg-[#f8f7f5] min-h-screen flex flex-col justify-center">
    <div class="w-full max-w-2xl mx-auto px-6 pt-40 pb-32">
      
      <div class="mb-4">
        <span class="font-['Roboto_Mono',_monospace] font-bold tracking-widest uppercase text-[13px] text-gray-400">
          THE STARTER · €890
        </span>
      </div>
      <h1 class="text-[40px] md:text-[56px] font-medium text-gray-900 mb-4 tracking-tight leading-tight">
        Let's build your site
      </h1>
      <p class="text-gray-500 text-lg mb-12 max-w-md">
        Tell us about your project and we'll handle everything from there. No call needed.
      </p>

      <form method="POST" action={actions.submitStarter} class="flex flex-col gap-8">
        <input type="hidden" name="lang" value="en" />
        <div class="input-group">
          <input 
            type="text" 
            name="name" 
            placeholder={contactPage.form.namePlaceholder} 
            required 
            class="minimal-input" 
          />
          {inputErrors?.name && <p class="error-text">{inputErrors.name}</p>}
        </div>

        <div class="input-group">
          <input 
            type="email" 
            name="email" 
            placeholder={contactPage.form.emailPlaceholder} 
            required 
            class="minimal-input" 
          />
          {inputErrors?.email && <p class="error-text">{inputErrors.email}</p>}
        </div>

        <div class="input-group">
          <textarea 
            name="message" 
            placeholder={contactPage.form.messagePlaceholder} 
            required 
            minlength="10"
            rows="3" 
            class="minimal-input resize-none"
          ></textarea>
          {inputErrors?.message && <p class="error-text">{inputErrors.message}</p>}
        </div>

        <Button type="submit" class="submit-btn w-full !px-6 !py-2.5 !rounded-2xl !text-sm mt-4">
          {contactPage.form.submitText}
        </Button>

      </form>
    </div>
  </main>

  <Footer data={footer} />
</Layout>

<style>
  .minimal-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid #111827;
    padding: 16px 0;
    font-size: 16px;
    color: #111827;
    outline: none;
    font-family: inherit;
    transition: border-color 0.3s ease, border-width 0.1s ease;
  }
  .minimal-input::placeholder {
    color: #111827;
    font-weight: 400;
    opacity: 1;
  }
  .minimal-input:focus {
    border-bottom-width: 2px;
    border-bottom-color: #000000;
    margin-bottom: -1px;
  }
  .submit-btn {
    background-color: #111827;
    color: #ffffff;
    width: 100%;
    padding: 20px;
    border-radius: 999px;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.4);
  }
  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 25px 45px -10px rgba(0, 0, 0, 0.5);
  }
  .error-text {
    color: #ef4444;
    font-size: 13px;
    margin-top: 6px;
  }
</style>
