---
import LandingLayout from '../../layouts/LandingLayout.astro';
import LandingHeader from '../../components/sections/LandingHeader.astro'; 
import Footer from '../../components/sections/Footer.astro'; 
import Button from '../../components/ui/Button.astro'; // Importamos tu botón

import enData from '../../content/i18n/en.json';

// Extraemos los datos generales y los específicos de esta landing page
const { footer, nav, starterPage } = enData;
---

<LandingLayout title="The Starter Package | Base Pages">
  
  <LandingHeader navData={nav} />

  <main class="starter-page">
    <section class="hero-section">
      <div class="container hero-inner">
        <div class="tagline">
          <div class="line"></div> {starterPage.hero.tagline}
        </div>
        <h1 class="main-title">
          <span class="title-bold">{starterPage.hero.titleBold}</span>
          <span class="title-light">{starterPage.hero.titleLight}</span>
        </h1>
        <p class="hero-subtitle">
          {starterPage.hero.subtitle}
        </p>
        <div class="hero-badges">
          <span class="pill">{starterPage.hero.priceBadge}</span>
          <span class="pill border-pill">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 16px; height: 16px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            {starterPage.hero.deliveryBadge}
          </span>
        </div>
      </div>
    </section>

    <section id="services-section" class="scroll-container">
      
      <div class="left-col">
        <div class="animation-wrapper">
          <svg id="starter-shape" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
            <rect id="outer-contour" x="50" y="50" width="300" height="300" rx="80" fill="none" stroke="#9ca3af" stroke-width="1.5" opacity="0" />
            <rect id="core-shape" x="70" y="70" width="260" height="260" rx="70" fill="url(#brand-gradient)" filter="url(#liquid-filter)" />
          </svg>
        </div>
        <a href={starterPage.finalCta.buttonUrl} class="btn btn-dark w-full" style="margin-top: 24px;">Start your project</a>
      </div>

      <div class="right-col">
        {starterPage.features.map((feature: any, index: number) => (
          <div class="feature-card">
            <div class="icon-wrapper">
              {index === 0 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>}
              {index === 1 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>}
              {index === 2 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>}
              {index === 3 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>}
            </div>
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="final-cta-section">
      <div class="container">
        <div class="cta-box">
          <h2>{starterPage.finalCta.headline}</h2>
          <p>{starterPage.finalCta.subtitle}</p>
          <div class="flex justify-center mt-6">
            <Button 
              href={starterPage.finalCta.buttonUrl} 
              class="bg-white text-gray-900 px-8 py-3.5 rounded-full font-medium hover:scale-105 transition-transform shadow-sm"
            >
              {starterPage.finalCta.buttonText}
            </Button>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer data={footer} />

</LandingLayout>

<style>
  /* === VARIABLES Y BASE (Solo lo que no maneja Tailwind en el layout global) === */
  :root {
    --text-main: #111827;
    --text-muted: #9ca3af;
  }

  .starter-page {
    /* Opcional: añade padding superior si tu LandingHeader no tiene el espacio suficiente */
    padding-top: 100px; 
  }

  .container { width: 100%; max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  svg { width: 18px; height: 18px; }

  /* === TIPOGRAFÍA EDITORIAL (Valores Móvil) === */
  .main-title { 
    margin: 0 0 32px 0; 
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .title-bold { 
    font-size: clamp(36px, 5vw, 64px); 
    font-weight: 600; 
    letter-spacing: -1px; 
    line-height: 1.05; 
    color: var(--text-main);
  }
  .title-light { 
    font-size: clamp(22px, 3vw, 36px); 
    font-weight: 400; 
    letter-spacing: -1px; 
    line-height: 1.2; 
    color: var(--text-main);
  }
  .hero-subtitle { 
    font-size: 18px; 
    line-height: 1.6; 
    font-weight: 400; 
    color: var(--text-main); 
    max-width: 600px; 
    margin: 0 0 40px 0; 
  }

  /* === HERO SECTION === */
  .hero-section { padding: 80px 0 40px 0; }
  .hero-inner { max-width: 800px; margin: 0 auto; text-align: center; display: flex; flex-direction: column; align-items: center; }
  .tagline { display: flex; align-items: center; gap: 15px; font-family: 'Roboto Mono', monospace; font-size: 13px; letter-spacing: 2px; color: var(--text-muted); margin-bottom: 30px; font-weight: 700; }
  .line { height: 2px; width: 30px; background: var(--text-main); }
  .hero-badges { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
  .pill { background: #ebebeb; color: var(--text-main); padding: 10px 20px; border-radius: 999px; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .border-pill { background: transparent; border: 1px solid #d1d5db; color: #6b7280; }

  /* === SCROLL ANIMATION SECTION === */
  .scroll-container { 
    display: flex; 
    flex-direction: column;
    gap: 40px; 
    padding: 20px 24px 80px 24px; 
    align-items: flex-start; 
  }

  .left-col { 
    flex: 1; 
    display: flex; 
    flex-direction: column; 
    position: sticky; 
    top: 80px; 
    z-index: 10; 
    background: transparent; 
    padding: 0 24px 20px 24px;
    margin: 0 -24px; 
    width: calc(100% + 48px);
  }

  .animation-wrapper { 
    width: 100%; 
    max-width: 260px; 
    margin: 0 auto;
    aspect-ratio: 1 / 1; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    background: transparent; 
    border-radius: 20px; 
    overflow: hidden; 
  }

  #starter-shape {
    width: 80%;
    height: 80%;
    opacity: 0;
    filter: blur(6px);
    transform: scale(0.96);
    transform-origin: center;
    will-change: transform, filter, opacity;
  }

  .right-col { 
    flex: 1; 
    display: flex; 
    flex-direction: column; 
    gap: 24px; 
    z-index: 1; 
    width: 100%;
  }

  .feature-card { 
    background: white; 
    padding: 32px 24px; 
    border-radius: 20px; 
    box-shadow: 0 4px 20px rgba(0,0,0,0.02); 
    border: 1px solid rgba(229, 231, 235, 0.4); 
  }

  .icon-wrapper { width: 48px; height: 48px; background: #f8f7f5; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 24px; color: var(--text-main); }
  .feature-card h3 { font-size: 22px; margin: 0 0 12px 0; font-weight: 600; color: var(--text-main); }
  .feature-card p { font-size: 15px; line-height: 1.7; font-weight: 400; color: var(--text-main); margin: 0; }

  /* === BOTONES EXTRA (Para complementar el Button.astro si es necesario) === */
  .btn { 
    display: inline-flex; 
    justify-content: center; 
    align-items: center; 
    padding: 16px 32px; 
    border-radius: 999px; 
    font-weight: 500; 
    font-size: 15px; 
    transition: transform 0.3s ease, background 0.3s ease; 
    cursor: pointer; 
    text-decoration: none;
  }
  .btn-dark { background: var(--text-main); color: white; }
  .btn-dark:hover { transform: scale(1.02); background: #1f2937; }

  .final-cta-section { padding: 0 0 80px 0; }
  .cta-box { background: var(--text-main); border-radius: 20px; padding: 60px 24px; text-align: center; color: white; }
  .cta-box h2 { font-size: clamp(28px, 4vw, 40px); font-weight: 500; letter-spacing: -1px; margin: 0 0 16px 0; }
  .cta-box p { color: #9ca3af; font-size: 18px; margin: 0 0 24px 0; }


  @media (max-width: 899px) {
    .animation-wrapper {
      display: none !important; 
    }
  }

  /* === EXPANSIÓN A ESCRITORIO === */
  @media (min-width: 900px) {
    .container { padding: 0 40px; }
    .hero-section { padding: 120px 0 80px 0; }
    .main-title { gap: 8px; }
    .title-bold { letter-spacing: -2px; }

    .scroll-container { 
      flex-direction: row; 
      gap: 80px; 
      padding: 40px 40px 120px 40px; 
    }
    .left-col { 
      top: 100px; 
      z-index: auto; 
      margin: 0; 
      width: auto;
      background: white; 
      padding: 40px; 
      border-radius: 20px; 
      box-shadow: 0 4px 20px rgba(0,0,0,0.02); 
      border: 1px solid rgba(229, 231, 235, 0.4);
    }
    .animation-wrapper { max-width: none; }
    .right-col { gap: 40px; width: auto; }
    .feature-card { padding: 40px; }

    .final-cta-section { padding: 0 0 120px 0; }
    .cta-box { padding: 80px 40px; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  // Función principal para inicializar animaciones
  function initStarterAnimations() {
    gsap.registerPlugin(ScrollTrigger);

    const dispMap = document.getElementById('disp-map');
    if (!dispMap) return;

    // Limpiar ScrollTriggers previos para ViewTransitions
    ScrollTrigger.getAll().forEach(t => t.kill());

    let mm = gsap.matchMedia();

    // ==========================================
    // DESKTOP LOGIC (Min-width: 900px)
    // ==========================================
    mm.add("(min-width: 900px)", () => {
      const shapeSvg = document.getElementById('starter-shape');
      const contour = document.getElementById('outer-contour');
      if(!shapeSvg || !contour) return;

      const tlDesktop = gsap.timeline({
        scrollTrigger: {
          trigger: "#services-section",
          start: "top 65%",
          end: "bottom bottom",
          scrub: 1, 
        }
      });

      tlDesktop.to(shapeSvg, { opacity: 1, filter: "blur(0px)", scale: 1, duration: 25, ease: "power2.out" })
        .to(dispMap, { attr: { scale: 12 }, duration: 12.5, ease: "sine.inOut" })
        .to(dispMap, { attr: { scale: 2 }, duration: 12.5, ease: "sine.inOut" })
        .to(contour, { opacity: 0.6, scale: 1.05, transformOrigin: "center", duration: 25, ease: "power1.inOut" }, "-=10")
        .to(shapeSvg, { scale: 1.01, duration: 25, ease: "none" });
    });

    // ==========================================
    // MOBILE LOGIC (Max-width: 899px)
    // ==========================================
    mm.add("(max-width: 899px)", () => {
      const isotipo = document.querySelector('.isotipo');
      const logoContainer = document.querySelector('.logo-container');
      const wordBase = document.querySelector('.word-base');
      const wordPages = document.querySelector('.word-pages');
      const connector = document.querySelector('.connector');
      const textContainer = document.querySelector('.text-container');
      
      if(!isotipo) return;

      // Estado Inicial Forzado
      gsap.set(logoContainer, { gap: "16px" });
      gsap.set(isotipo, { rotation: -90, width: "26px", height: "48px", borderRadius: "3px" });
      gsap.set(textContainer, { marginTop: "-3px" });
      gsap.set(wordBase, { x: 0, y: 0 });
      gsap.set(wordPages, { x: 0, y: 0 });
      gsap.set(connector, { width: "14px", opacity: 1, x: 0 });

      const tlMobile = gsap.timeline({
        scrollTrigger: {
          trigger: "#services-section",
          start: "top 70%",
          end: "bottom 80%",
          scrub: 1, 
        }
      });

      // Transformación inicial
      tlMobile.to(logoContainer, { gap: "7px", duration: 25, ease: "power2.inOut" }, 0)
        .to(isotipo, { rotation: 0, width: "32px", height: "32px", borderRadius: "10px", duration: 25, ease: "power2.inOut" }, 0)
        .to(textContainer, { marginTop: "-5px", duration: 25, ease: "power2.inOut" }, 0)
        .to(wordBase, { x: 0, y: -9, duration: 25, ease: "power2.inOut" }, 0)
        .to(wordPages, { x: -58, y: 9, duration: 25, ease: "power2.inOut" }, 0)
        .to(connector, { width: 0, opacity: 0, x: -10, duration: 25, ease: "power2.inOut" }, 0)
        // Distorsión líquida
        .to(dispMap, { attr: { scale: 15 }, duration: 12.5, ease: "sine.inOut" }, 25)
        .to(dispMap, { attr: { scale: 3 }, duration: 12.5, ease: "sine.inOut" }, 37.5)
        // Borde delgado y empuje de texto (Con tu ajuste de máscara #f8f7f5)
        .to(isotipo, {
          boxShadow: "0 0 0 4px #f8f7f5, 0 0 0 5.5px rgba(156, 163, 175, 0.3)",
          duration: 25,
          ease: "power1.inOut"
        }, 40)
        .to(wordBase, { x: 6, duration: 20, ease: "power1.inOut" }, 40)
        .to(wordPages, { x: -52, duration: 20, ease: "power1.inOut" }, 45)
        // Respiración final
        .to(isotipo, { scale: 1.05, duration: 25, ease: "none" }, 75);
    });
  }

  // Inicializamos al cargar el documento (la primera vez)
  document.addEventListener('DOMContentLoaded', initStarterAnimations);
  
  // Y reinicializamos cada vez que Astro carga una página con ViewTransitions
  document.addEventListener('astro:page-load', initStarterAnimations);
</script>