---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/sections/Header.astro';
import Footer from '../../../components/sections/Footer.astro';
import esData from '../../../content/i18n/es.json';
import { Image } from 'astro:assets';

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/**/*.{jpeg,jpg,png,gif}');

export async function getStaticPaths() {
  const projects = [
    {
      id: 'carma-retreats',
      title: 'Carma Retreats',
      subtitle: 'Connection, Culture, and Community',
      headline: 'Blending wellness and code into a bold digital system',
      challenge: 'Visualizing peace through motion and color',
      challengeText: 'Creating a digital space that feels as calm as a Sri Lankan sunrise while maintaining high technical performance.',
      results: 'A vibrant system for a bold digital future',
      resultsText: 'A seamless booking experience and a visual identity that resonates with modern travelers.',
      nextCase: 'Cornelia Jaeger',
      nextId: 'cornelia-jaeger',
      mainImgDesk: '/src/assets/images/portfolio-grid/carma-main.jpg',
      secImgDesk: '/src/assets/images/works/carma/carma-01-desktop.png',
      tertiaryImgDesk: '/src/assets/images/works/carma/carma-02-desktop.png',
      nextImg: '/src/assets/images/portfolio-grid/cornelia-main.jpg'
    },
    {
      id: 'cornelia-jaeger',
      title: 'Cornelia Jaeger',
      subtitle: 'Holistic Occupational Therapy',
      headline: 'Empowering families through thoughtful digital design',
      challenge: 'Structuring care and professional trust',
      challengeText: 'Communicating clinical expertise with a warm, accessible approach for parents in need of support.',
      results: 'Clarity and empathy in every interaction',
      resultsText: 'An intuitive platform that bridges the gap between therapy and home-based support.',
      nextCase: 'Carma Retreats',
      nextId: 'carma-retreats',
      mainImgDesk: '/src/assets/images/portfolio-grid/cornelia-main.jpg',
      secImgDesk: '/src/assets/images/works/cornelia/cornelia-01-desktop.png',
      tertiaryImgDesk: '/src/assets/images/works/cornelia/cornelia-02-desktop.png',
      nextImg: '/src/assets/images/portfolio-grid/carma-main.jpg' 
    }
  ];

  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} - Noura`}>
  <Header navData={esData.nav} />  
  <main class="work-detail">
    
    <section class="intro-header container-base">
      <div class="meta">
        <span class="client-name">{project.title.toUpperCase()}</span>
        <span class="subtitle">{project.subtitle}</span>
      </div>
      <h1>{project.headline}</h1>
    </section>

    <div class="main-image-wrapper container-base">
      <Image 
        src={images[project.mainImgDesk]()} 
        alt={project.title} 
        class="full-img" 
        loading="eager"
        widths={[400, 768, 1200]} 
        sizes="(max-width: 768px) 100vw, 1200px"
      />
    </div>

    <section class="grid-section container-base">
      <div class="text-content">
        <span class="label">CHALLENGE</span>
        <h2>{project.challenge}</h2>
        <p>{project.challengeText}</p>
      </div>
      <div class="image-content">
        <Image 
          src={images[project.secImgDesk]()} 
          alt="Challenge visual" 
          class="rounded-img" 
          widths={[400, 768]} 
          sizes="(max-width: 768px) 100vw, 768px"
        />
      </div>
    </section>

    <div class="full-image-wrapper container-base">
      <Image 
        src={images[project.tertiaryImgDesk]()} 
        alt="Visual system details" 
        class="full-img" 
        loading="lazy"
        widths={[400, 768, 1200]} 
        sizes="(max-width: 768px) 100vw, 1200px"
      />
    </div>

    <section class="results-section container-base">
       <div class="text-content">
        <span class="label">RESULTS</span>
        <h2>{project.results}</h2>
      </div>
      <div class="results-description">
        <p>{project.resultsText}</p>
      </div>
    </section>

    <section class="next-case container-base">
       <div class="next-label">
         Next case <a href={`/es/works/${project.nextId}`} class="badge">{project.nextCase.toUpperCase()}</a>
       </div>
       <a href={`/es/works/${project.nextId}`} class="next-img-link">
         <Image 
           src={images[project.nextImg]()} 
           alt="Next project" 
           widths={[400, 900]} 
           sizes="(max-width: 768px) 100vw, 900px"
         />
       </a>
    </section>
  </main>
  <Footer data={esData.footer} />
</Layout>

<style>
  .work-detail { padding-top: 100px; background: #f8f7f5; }
  
  .intro-header { padding-bottom: 40px; }
  .meta { display: flex; gap: 20px; margin-bottom: 40px; font-size: 14px; font-weight: 500; }
  .client-name { color: #1a1a1a; }
  .subtitle { color: #888; }
  h1 { font-size: 28px; line-height: 1.1; font-weight: 500; letter-spacing: -1px; max-width: 900px; margin: 0; }

  .main-image-wrapper, .full-image-wrapper { margin-bottom: 60px; }
  
  .full-img, .rounded-img { width: 100%; height: 218px; border-radius: 24px; object-fit: cover; display: block; }

  .grid-section { display: grid; grid-template-columns: 1fr; gap: 40px; margin-bottom: 60px; align-items: center; }
  .label { font-size: 12px; font-weight: 700; color: #1a1a1a; display: block; margin-bottom: 24px; letter-spacing: 1px; }
  h2 { font-size: 32px; line-height: 1.2; font-weight: 500; letter-spacing: -1px; margin-top: 0; }
  p { font-size: 18px; line-height: 1.6; color: #555; max-width: 440px; }

  .results-section { display: flex; flex-direction: column; justify-content: space-between; align-items: flex-start; margin-bottom: 80px; }
  .results-section h2 { max-width: 500px; }
  .results-description { margin-top: 20px; max-width: 440px; }

  .next-case { border-top: 1px solid #ddd; padding-top: 80px; padding-bottom: 80px; text-align: center; }
  .next-label { font-size: 18px; margin-bottom: 40px; color: #1a1a1a; }
  .badge { background: #e8e8e8; padding: 10px 20px; border-radius: 30px; text-decoration: none; color: #000; font-weight: 600; font-size: 13px; margin-left: 10px; transition: background 0.3s ease; }
  .badge:hover { background: #dcdcdc; }
  .next-img-link { display: block; margin-top: 40px; }
  .next-img-link img { width: 100%; max-width: 900px; height: auto; border-radius: 24px; margin: 0 auto; transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .next-img-link:hover img { transform: scale(1.02); }

  @media (min-width: 768px) {
    .work-detail { padding-top: 140px; }
    .intro-header { padding-bottom: 60px; }
    h1 { font-size: clamp(40px, 8vw, 84px); letter-spacing: -2px; }
    
    .main-image-wrapper, .full-image-wrapper { margin-bottom: 120px; }
    
    .full-img { height: 464px; }
    .rounded-img { height: auto; }
    
    .grid-section { grid-template-columns: 1fr 1.5fr; gap: 80px; margin-bottom: 120px; }
    .grid-section .text-content {
      position: sticky;
      top: 140px; 
      align-self: start; 
      margin-top: 0;
    }
    h2 { font-size: 40px; }
    
    .results-section { 
      display: grid; 
      grid-template-columns: 1fr 1fr; 
      gap: 80px; 
      margin-bottom: 150px; 
      align-items: start; 
    }
    .results-description { margin-top: 0; }
    
    .next-case { padding-top: 120px; padding-bottom: 120px; }
  }

  @media (min-width: 1024px) {
    h1 { font-size: 56px; }
    
    .full-img { height: 605px; }
    
    .rounded-img { height: 534px; }
    
    .next-img-link img { 
      max-width: 576px; 
      height: 288px; 
      object-fit: cover; 
    }
  }
</style>