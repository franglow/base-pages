---
import Layout from '../../../layouts/Layout.astro';
import Button from '../../../components/ui/Button.astro';
import Header from '../../../components/sections/Header.astro';
import DesignerBanner from '../../../components/sections/DesignerBanner.astro';
import Footer from '../../../components/sections/Footer.astro'; 

import deData from '../../../content/i18n/de.json';

const { services, footer, nav, designerBanner } = deData;
---

<Layout title="Dienstleistungen - base-pages">
  <Header navData={nav} />
  
  <main style="padding-top: 100px;" class="bg-[#f8f7f5]">
    
    <section class="services-section">
      <div class="container">
        <h2 class="section-title">
          {services.headerTitle}
          <sup class="text-[14px] bg-gray-900 text-white rounded-full w-[20px] h-[20px] flex items-center justify-center font-semibold mt-2 md:mt-4">
            {services.headerCount}
          </sup>
        </h2>
        
        <div class="projects-grid">
          {services.items.map((pkg: any, index: number) => (
            <article class="project-card observe-card">
              <div class="image-container">
                <a href={pkg.url} class="image-link">
                  <div class="scroll-zoom-wrapper">

                    {/* SHAPE 1: THE STARTER (Squircle) */}
                    {index === 0 && (
                      <div class="w-32 h-32 md:w-40 md:h-40 rounded-[32px] md:rounded-[40px] brand-gradient shape-breath shadow-lg shadow-black/5" />
                    )}

                    {/* SHAPE 2: THE GROWTH (Pill) */}
                    {index === 1 && (
                      <div class="w-40 h-24 md:w-48 md:h-28 rounded-[40px] md:rounded-[48px] brand-gradient shape-tilt shadow-lg shadow-black/5" />
                    )}

                    {/* SHAPE 3: THE SCALE (Overlapping Squircles) */}
                    {index === 2 && (
                      <div class="relative w-32 h-32 md:w-40 md:h-40">
                        <div class="absolute inset-0 rounded-[32px] md:rounded-[40px] brand-gradient opacity-60 mix-blend-multiply shape-overlap-1" />
                        <div class="absolute inset-0 rounded-[32px] md:rounded-[40px] brand-gradient opacity-90 backdrop-blur-sm shape-overlap-2 shadow-lg shadow-black/5" />
                      </div>
                    )}

                  </div>
                </a>
              </div>
              
              <div class="project-info text-center flex flex-col items-center">
                <h3>{pkg.title}</h3>
                
                <p>
                  {pkg.description || pkg.subtitle}
                  <a href={pkg.url} class="md:hidden group inline-flex items-center gap-1 text-gray-900 font-medium hover:text-gray-500 transition-colors ml-1 whitespace-nowrap">
                    Explore package
                    <svg class="w-3.5 h-3.5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </a>
                </p>
                
                <div class="flex flex-wrap justify-center items-center gap-4 mt-6">
                  
                  <div class="flex items-center gap-3">
                    <span class="bg-[#ebebeb] text-gray-900 text-[14px] font-medium px-4 py-1.5 rounded-full whitespace-nowrap">
                      {pkg.price}
                    </span>
                    <span class="bg-[#ebebeb] text-gray-600 text-[14px] font-medium px-4 py-1.5 rounded-full flex items-center gap-1.5 whitespace-nowrap">
                      <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      {pkg.delivery}
                    </span>
                  </div>

                  <a href={pkg.url} class="hidden md:inline-flex group items-center gap-1.5 text-gray-900 font-medium text-[15px] hover:text-gray-500 transition-colors">
                    Explore package
                    <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </a>
                  
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 pb-24 md:pb-32">
      <div class="bg-white rounded-[20px] p-10 md:p-16 text-center shadow-sm border border-gray-100 flex flex-col items-center">
        <span class="font-['Roboto_Mono',_monospace] font-bold tracking-widest uppercase text-[14px] text-gray-400 mb-6 block">
          {services.cta.pill}
        </span>
        
        <h3 class="text-[28px] md:text-4xl font-medium text-gray-900 leading-tight mb-8 max-w-2xl">
          {services.cta.title}
        </h3>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-8">
          <Button href={services.cta.buttonUrl} class="bg-black text-white px-6 py-2.5 !rounded-2xl text-sm font-medium hover:scale-105 transition-transform shadow-sm">
            {services.cta.buttonText}
          </Button>
          
          <a href={services.cta.exploreUrl} class="group inline-flex items-center gap-1.5 text-gray-900 font-medium text-[16px] hover:text-gray-500 transition-colors">
            {services.cta.exploreText}
            <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
        
        <p class="text-[14px] md:text-[16px] text-gray-500 max-w-lg mx-auto leading-relaxed">
          {services.cta.note}
        </p>
      </div>
    </section>

    <section id="partnership" class="max-w-7xl mx-auto px-4 md:px-6 pb-32">
      <div class="bg-gray-900 rounded-[20px] p-10 md:p-16 lg:p-24 text-white grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center shadow-2xl">
        
        <div>
          <span class="font-['Roboto_Mono',_monospace] font-bold tracking-widest uppercase text-sm mb-6 block text-gray-400">
            {services.partnership.tagline}
          </span>
          <h2 class="text-[32px] md:text-5xl lg:text-6xl font-medium leading-tight mb-8 text-white">
            {services.partnership.headline}
          </h2>
          <p class="text-[16px] leading-[24px] md:text-lg md:leading-relaxed text-gray-400 max-w-lg mb-12">
            {services.partnership.description}
          </p>
          <Button href={services.partnership.cta.buttonUrl} class="bg-white text-gray-900 hover:bg-gray-200 px-6 py-2.5 !rounded-2xl text-sm font-medium hover:scale-105 transition-transform shadow-sm">
            {services.partnership.cta.buttonText}
          </Button>
        </div>

        <div class="flex flex-col gap-8 md:gap-10">
          {services.partnership.pillars.map((pillar: any) => (
            <div class="border-t border-gray-800 pt-6">
              <h3 class="text-xl md:text-2xl font-semibold mb-3 text-gray-100">{pillar.title}</h3>
              <p class="text-[16px] leading-[24px] md:text-lg md:leading-relaxed text-gray-400">{pillar.description}</p>
            </div>
          ))}
        </div>

      </div>
    </section> 
  </main>
  
  <Footer data={footer} />
</Layout>

<style>
  .services-section {
    padding: clamp(60px, 8vw, 100px) 24px;
    background-color: #f8f7f5;
    text-align: center;
  }

  .container {
    max-width: 1000px; 
    margin: 0 auto;
  }

  .section-title {
    font-family: 'Inter', sans-serif; 
    font-size: clamp(40px, 6vw, 64px); 
    font-weight: 500;
    letter-spacing: -2px;
    margin-bottom: clamp(32px, 6vw, 80px);
    display: inline-flex;
    align-items: flex-start;
    justify-content: center;
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: clamp(60px, 10vw, 120px); 
  }

  .project-card {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .image-container {
    position: relative;
    width: 100%;
    margin-bottom: clamp(24px, 4vw, 40px);
  }

  .scroll-zoom-wrapper {
    width: 100%;
    height: 100%;
    will-change: transform;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-link {
    display: block;
    overflow: hidden; 
    border-radius: 20px;
    transform: translateZ(0);
    background-color: #f8f7f5;
    border: 1px solid #e5e5e5;
    aspect-ratio: 16 / 9;
  }

  .project-info h3 {
    font-size: clamp(16px, 4vw, 28px); 
    font-weight: 600;
    margin-bottom: 12px;
    color: #1a1a1a;
  }

  .project-info p {
    font-size: clamp(14px, 3vw, 20px); 
    color: #666666;
    max-width: 600px;
    line-height: 1.4;
    margin: 0 auto;
    font-weight: 400;
  }

  /* --- BRAND GRADIENT & GEOMETRY ANIMATIONS --- */
  .brand-gradient {
    background: linear-gradient(135deg, #A8BFAF 0%, #E8DDC8 50%, #F6D7C8 100%);
    background-size: 200% 200%;
    animation: gradientShift 8s ease infinite paused;
  }
  .observe-card.is-in-view .brand-gradient {
    animation-play-state: running;
  }
  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .shape-breath {
    animation: breath 6s ease-in-out infinite paused;
  }
  .observe-card.is-in-view .shape-breath {
    animation-play-state: running;
  }
  @keyframes breath {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  .shape-tilt {
    transform: rotate(-35deg);
    animation: tilt 8s ease-in-out infinite paused;
  }
  .observe-card.is-in-view .shape-tilt {
    animation-play-state: running;
  }
  @keyframes tilt {
    0%, 100% { transform: rotate(-35deg) scale(1); }
    50% { transform: rotate(-25deg) scale(1.03); }
  }

  .shape-overlap-1 {
    animation: overlap1 6s ease-in-out infinite paused;
  }
  .observe-card.is-in-view .shape-overlap-1 {
    animation-play-state: running;
  }
  .shape-overlap-2 {
    animation: overlap2 6s ease-in-out infinite paused;
  }
  .observe-card.is-in-view .shape-overlap-2 {
    animation-play-state: running;
  }
  @keyframes overlap1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-12px, -12px) scale(1.02); }
  }
  @keyframes overlap2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(12px, 12px) scale(0.98); }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initServicesScrubZoom() {
    gsap.registerPlugin(ScrollTrigger);

    // IntersectionObserver for CSS animation visibility
    const observerOptions = { root: null, rootMargin: "0px", threshold: 0.1 };
    const cardObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-in-view');
        } else {
          entry.target.classList.remove('is-in-view');
        }
      });
    }, observerOptions);
    document.querySelectorAll('.observe-card').forEach(card => cardObserver.observe(card));

    // GSAP scroll zoom
    const cards = document.querySelectorAll('.project-card');

    cards.forEach((card) => {
      const wrapper = card.querySelector('.scroll-zoom-wrapper');

      gsap.fromTo(wrapper, 
        { scale: 1 }, 
        {
          scale: 1.15,
          ease: "none",
          scrollTrigger: {
            trigger: card,
            start: "top bottom", 
            end: "bottom top",   
            scrub: true 
          }
        }
      );
    });
  }

  initServicesScrubZoom();
  document.addEventListener('astro:page-load', initServicesScrubZoom);
</script>