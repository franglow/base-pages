---
import LandingLayout from '../../../layouts/LandingLayout.astro';
import LandingHeader from '../../../components/sections/LandingHeader.astro'; 
import Footer from '../../../components/sections/Footer.astro'; 
import Button from '../../../components/ui/Button.astro';
import FounderSignature from '../../../components/sections/FounderSignature.astro';
import CaseStudySection from '../../../components/sections/CaseStudySection.astro';

import { getI18n } from '../../../i18n/utils';
import { generateHreflangLinks } from '../../../i18n/hreflang';
import { SUPPORTED_LANGUAGES, DEFAULT_LANGUAGE } from '../../../i18n/config';
import type { Language } from '../../../i18n/config';
import { getOrganizationSchema, getServiceSchema, getBreadcrumbSchema } from '../../../utils/schema';

export function getStaticPaths() {
  return SUPPORTED_LANGUAGES
    .filter((lang) => lang !== DEFAULT_LANGUAGE)
    .map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Language };
const data = getI18n(lang);
const { footer, nav, carePage } = data;
const hreflangLinks = generateHreflangLinks('/services/care', 'https://base-pages.com');
const canonicalUrl = `https://base-pages.com/${lang}/services/care`;
const jsonLd = [
  getOrganizationSchema(),
  getBreadcrumbSchema([
    { name: 'Home', url: `/${lang}/` },
    { name: 'Services', url: `/${lang}/services` },
    { name: 'Continuous Care', url: `/${lang}/services/care` },
  ]),
  getServiceSchema({
    name: 'Continuous Care',
    description: carePage.hero.titleLight,
    price: '190',
    url: `/${lang}/services/care`,
  }),
];
---

<LandingLayout
  title="Continuous Care | base-pages"
  description={carePage.hero.titleLight}
  canonicalUrl={canonicalUrl}
  lang={lang}
  hreflangLinks={hreflangLinks}
  jsonLd={jsonLd}
>
  
  <LandingHeader navData={nav} />

  <main id="tier-care" class="care-page">
    <section class="hero-section">
      <div class="container hero-inner">
        <div class="tagline">
          <div class="line"></div> {carePage.hero.tagline}
        </div>
        <h1 class="main-title">
          <span class="title-bold">{carePage.hero.titleBold}</span>
          <span class="title-light">{carePage.hero.titleLight}</span>
        </h1>
        <p class="hero-subtitle">
          {carePage.hero.subtitle}
        </p>
        <div class="hero-badges">
          <span class="pill">{carePage.hero.priceBadge}</span>
          <span class="pill border-pill">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 16px; height: 16px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            {carePage.hero.deliveryBadge}
          </span>
        </div>
      </div>
    </section>

    <section id="services-section" class="scroll-container">
      
      <div class="left-col">
        <div class="animation-wrapper">
          <svg id="care-shape" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="care-glow" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="rgba(255,255,255,0)" />
                <stop offset="50%" stop-color="rgba(255,255,255,0.8)" />
                <stop offset="100%" stop-color="rgba(255,255,255,0)" />
              </linearGradient>
              <clipPath id="horizon-clip">
                <rect x="40" y="150" width="320" height="100" rx="50" />
              </clipPath>
              <filter id="gentle-wave" x="-20%" y="-20%" width="140%" height="140%">
                <feTurbulence type="fractalNoise" baseFrequency="0.004" numOctaves="1" result="noise" id="wave-noise"/>
                <feDisplacementMap in="SourceGraphic" in2="noise" scale="0" xChannelSelector="R" yChannelSelector="G" id="wave-disp"/>
              </filter>
            </defs>

            <g id="care-group" filter="url(#gentle-wave)">
              <rect id="horizon-base" x="40" y="150" width="320" height="100" rx="50" fill="url(#brand-gradient)" />
              <rect id="horizon-glow" x="-100" y="150" width="100" height="100" fill="url(#care-glow)" clip-path="url(#horizon-clip)" opacity="0" />
            </g>
          </svg>
        </div>
        <Button href={carePage.finalCta.buttonUrl} class="bg-black text-white w-full justify-center py-3.5 !rounded-2xl text-[15px] font-medium hover:scale-105 transition-transform">
          Secure your site
        </Button>
      </div>

      <div class="right-col">
        {carePage.features.map((feature: any, index: number) => (
          <div class="feature-card">
            <div class="icon-wrapper">
              {index === 0 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>}
              {index === 1 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>}
              {index === 2 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>}
              {index === 3 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>}
            </div>
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </div>
        ))}
      </div>
    </section>

    <CaseStudySection data={carePage.caseStudy} />

    <section class="final-cta-section">
      <div class="container">
        <FounderSignature
          name={carePage.founder.name}
          role={carePage.founder.role}
          message={carePage.founder.message}
          class="mb-6"
        />
        <div class="cta-box">
          <h2>{carePage.finalCta.headline}</h2>
          <p>{carePage.finalCta.subtitle}</p>
          <div class="flex justify-center mt-6">
            <Button 
              href={carePage.finalCta.buttonUrl} 
              class="bg-white text-gray-900 px-8 py-3.5 !rounded-2xl font-medium hover:scale-105 transition-transform shadow-sm"
            >
              {carePage.finalCta.buttonText}
            </Button>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer data={footer} />

</LandingLayout>

<style>
  :root {
    --text-main: #111827;
    --text-muted: #9ca3af;
  }

  .care-page { padding-top: 100px; }
  .container { width: 100%; max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  svg { width: 18px; height: 18px; }

  .main-title { margin: 0 0 32px 0; display: flex; flex-direction: column; gap: 4px; }
  .title-bold { font-size: clamp(36px, 5vw, 64px); font-weight: 600; letter-spacing: -1px; line-height: 1.05; color: var(--text-main); }
  .title-light { font-size: clamp(22px, 3vw, 36px); font-weight: 400; letter-spacing: -1px; line-height: 1.2; color: var(--text-main); }
  .hero-subtitle { font-size: 18px; line-height: 1.6; font-weight: 400; color: var(--text-main); max-width: 600px; margin: 0 0 40px 0; }

  .hero-section { padding: 80px 0 40px 0; }
  .hero-inner { max-width: 800px; margin: 0 auto; text-align: center; display: flex; flex-direction: column; align-items: center; }
  .tagline { display: flex; align-items: center; gap: 15px; font-family: 'Roboto Mono', monospace; font-size: 13px; letter-spacing: 2px; color: var(--text-muted); margin-bottom: 30px; font-weight: 700; }
  .line { height: 2px; width: 30px; background: var(--text-main); }
  .hero-badges { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
  .pill { background: #ebebeb; color: var(--text-main); padding: 10px 20px; border-radius: 999px; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .border-pill { background: transparent; border: 1px solid #d1d5db; color: #6b7280; }

  .scroll-container { display: flex; flex-direction: column; gap: 40px; padding: 20px 24px 80px 24px; align-items: flex-start; }

  .left-col { flex: 1; display: flex; flex-direction: column; position: sticky; top: 80px; z-index: 10; background: transparent; padding: 0 24px 20px 24px; margin: 0 -24px; width: calc(100% + 48px); }

  .animation-wrapper { width: 100%; max-width: 260px; margin: 0 auto; aspect-ratio: 1 / 1; display: flex; align-items: center; justify-content: center; background: transparent; border-radius: 20px; overflow: hidden; }

  #care-shape { width: 100%; height: 100%; transform-origin: center; will-change: transform, filter, opacity; }

  .right-col { flex: 1; display: flex; flex-direction: column; gap: 24px; z-index: 1; width: 100%; }
  
  .feature-card { background: white; padding: 32px 24px; border-radius: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.02); border: 1px solid rgba(229, 231, 235, 0.4); }
  .icon-wrapper { width: 48px; height: 48px; background: #f8f7f5; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 24px; color: var(--text-main); }
  .feature-card h3 { font-size: 22px; margin: 0 0 12px 0; font-weight: 600; color: var(--text-main); }
  .feature-card p { font-size: 15px; line-height: 1.7; font-weight: 400; color: var(--text-main); margin: 0; }

  .final-cta-section { padding: 0 0 80px 0; }
  .cta-box { background: var(--text-main); border-radius: 20px; padding: 60px 24px; text-align: center; color: white; }
  .cta-box h2 { font-size: clamp(28px, 4vw, 40px); font-weight: 500; letter-spacing: -1px; margin: 0 0 16px 0; }
  .cta-box p { color: #9ca3af; font-size: 18px; margin: 0 0 24px 0; }

  @media (max-width: 899px) {
    .animation-wrapper { display: none !important; }
  }

  @media (min-width: 900px) {
    .container { padding: 0 40px; }
    .hero-section { padding: 120px 0 80px 0; }
    .main-title { gap: 8px; }
    .title-bold { letter-spacing: -2px; }
    .scroll-container { flex-direction: row; gap: 80px; padding: 40px 40px 120px 40px; }
    .left-col { top: 100px; z-index: auto; margin: 0; width: auto; background: white; padding: 40px; border-radius: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.02); border: 1px solid rgba(229, 231, 235, 0.4); }
    .animation-wrapper { max-width: none; }
    .right-col { gap: 40px; width: auto; }
    .feature-card { padding: 40px; }
    .final-cta-section { padding: 0 0 120px 0; }
    .cta-box { padding: 80px 40px; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initCareAnimations() {
    gsap.registerPlugin(ScrollTrigger);
    ScrollTrigger.getAll().forEach(t => t.kill());

    let mm = gsap.matchMedia();

    mm.add("(min-width: 900px)", () => {
      const shapeSvg = document.getElementById('care-shape');
      const horizonGlow = document.getElementById('horizon-glow');
      const waveDisp = document.getElementById('wave-disp');

      if(!shapeSvg) return;

      gsap.set(shapeSvg, { opacity: 0, filter: "blur(12px)", y: 0, scale: 1 });
      gsap.set(horizonGlow, { attr: { x: -100 }, opacity: 0 });
      gsap.set(waveDisp, { attr: { scale: 0 } });

      const tlDesktop = gsap.timeline({
        scrollTrigger: {
          trigger: "#services-section",
          start: "top 65%",
          end: "bottom bottom",
          scrub: 1, 
        }
      });

      tlDesktop.to(shapeSvg, { opacity: 1, filter: "blur(0px)", duration: 25, ease: "power2.out" }, 0)
      .to(waveDisp, { attr: { scale: 12 }, duration: 25, ease: "sine.inOut" }, 25)
      
      .to(horizonGlow, { opacity: 1, duration: 5, ease: "power1.inOut" }, 50)
      .to(horizonGlow, { attr: { x: 380 }, duration: 25, ease: "none" }, 50)
      .to(horizonGlow, { opacity: 0, duration: 5, ease: "power1.inOut" }, 70)
      
      .to(waveDisp, { attr: { scale: 2 }, duration: 25, ease: "sine.inOut" }, 75)
      .to(shapeSvg, { y: 15, scale: 0.98, duration: 25, ease: "power2.inOut" }, 75);
    });

    mm.add("(max-width: 899px)", () => {
      const isotipo = document.querySelector('.isotipo');
      const logoContainer = document.querySelector('.logo-container');
      const wordBase = document.querySelector('.word-base');
      const wordPages = document.querySelector('.word-pages');
      const connector = document.querySelector('.connector');
      const textContainer = document.querySelector('.text-container');
      const dispMapGlobal = document.getElementById('disp-map'); 
      
      if(!isotipo) return;

      gsap.set(logoContainer, { gap: "16px" });
      gsap.set(isotipo, { rotation: -90, width: "26px", height: "48px", borderRadius: "3px" });
      gsap.set(textContainer, { marginTop: "-3px" });
      gsap.set(wordBase, { x: 0, y: 0 });
      gsap.set(wordPages, { x: 0, y: 0 });
      gsap.set(connector, { width: "14px", opacity: 1, x: 0 });

      const tlMobile = gsap.timeline({
        scrollTrigger: {
          trigger: "#services-section",
          start: "top 70%",
          end: "bottom 80%",
          scrub: 1, 
        }
      });

      tlMobile.to(logoContainer, { gap: "7px", duration: 25, ease: "power2.inOut" }, 0)
        .to(isotipo, { rotation: 0, width: "32px", height: "32px", borderRadius: "10px", duration: 25, ease: "power2.inOut" }, 0)
        .to(textContainer, { marginTop: "-5px", duration: 25, ease: "power2.inOut" }, 0)
        .to(wordBase, { x: 0, y: -9, duration: 25, ease: "power2.inOut" }, 0)
        .to(wordPages, { x: -58, y: 9, duration: 25, ease: "power2.inOut" }, 0)
        .to(connector, { width: 0, opacity: 0, x: -10, duration: 25, ease: "power2.inOut" }, 0)
        .to(dispMapGlobal, { attr: { scale: 12 }, duration: 12.5, ease: "sine.inOut" }, 25)
        .to(dispMapGlobal, { attr: { scale: 2 }, duration: 12.5, ease: "sine.inOut" }, 37.5)
        .to(isotipo, {
          boxShadow: "0 0 0 4px #f8f7f5, 0 0 0 5.5px rgba(168, 191, 175, 0.5)",
          duration: 25,
          ease: "power1.inOut"
        }, 40)
        .to(wordBase, { x: 6, duration: 20, ease: "power1.inOut" }, 40)
        .to(wordPages, { x: -52, duration: 20, ease: "power1.inOut" }, 45)
        .to(isotipo, { scale: 1.05, duration: 25, ease: "none" }, 75);
    });
  }

  document.addEventListener('DOMContentLoaded', initCareAnimations);
  document.addEventListener('astro:page-load', initCareAnimations);
</script>
