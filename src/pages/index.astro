---
import Layout from '../layouts/Layout.astro';
import Header from '../components/sections/Header.astro';
import Hero from '../components/sections/Hero.astro';
import RevealSection from '../components/sections/RevealSection.astro';
import PortfolioGrid from '../components/sections/PortfolioGrid.astro';
import Services from '../components/sections/Services.astro';
import DesignerBanner from '../components/sections/DesignerBanner.astro';
import Footer from '../components/sections/Footer.astro';
import enData from '../content/i18n/en.json';
---

<Layout title="Base Pages">
  <Header navData={enData.nav} />
  <main>
    <Hero data={enData.hero} />
    <div class="max-w-7xl mx-auto px-6 mt-20 md:mt-32">
      <div class="w-full border-t border-gray-200"></div>
    </div>
    <RevealSection />
    <PortfolioGrid />
    <div class="max-w-7xl mx-auto px-6">
      <div class="w-full border-t border-gray-200"></div>
    </div>
    <Services data={enData.services} />
    <DesignerBanner data={enData.designerBanner} />
  </main>
  <Footer data={enData.footer} />
</Layout>
